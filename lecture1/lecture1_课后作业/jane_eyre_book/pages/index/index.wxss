/* pages/index/index.wxss - 页面样式文件 */

/* 页面容器 */
.container {
  padding: 0 30rpx 40rpx;
  background-color: #F5F0EB;
  min-height: 100vh;
}

/* ==================== 模块一：封面模块 ==================== */
.cover-section {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 40rpx 0 30rpx;
  background: linear-gradient(135deg, #FAF7F2 0%, #F0EBE3 100%);
  border-radius: 24rpx;
  margin-bottom: 30rpx;
}

/* 封面图片 */
.cover-image {
  width: 220rpx;
  height: 320rpx;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
  margin-right: 24rpx;
}

/* 标题区域 */
.title-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 10rpx 0;
}

/* 主标题 */
.main-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2C2C2C;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

/* 副标题 */
.sub-title {
  font-size: 24rpx;
  color: #8B8680;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

/* 评分标签 */
.rating-badge {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  background: linear-gradient(135deg, #D4A574 0%, #C4956A 100%);
  border-radius: 32rpx;
  padding: 12rpx 28rpx;
  width: fit-content;
}

.rating-score {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-right: 8rpx;
}

.rating-text {
  font-size: 24rpx;
  color: #FFFFFF;
}

/* ==================== 模块二：基础信息模块 ==================== */
.info-section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 信息条目 */
.info-item {
  display: flex;
  flex-direction: row;
  margin-bottom: 20rpx;
  line-height: 1.8;
}

.info-item:last-of-type {
  margin-bottom: 24rpx;
}

/* 信息标签 */
.info-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #5A554E;
  flex-shrink: 0;
  width: 140rpx;
}

/* 信息值 */
.info-value {
  font-size: 28rpx;
  color: #3D3D3D;
  flex: 1;
}

/* 标签区域 */
.tags-section {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #E8E3DD;
}

/* 单个标签 */
.tag {
  background-color: #F5EDE4;
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
}

.tag-text {
  font-size: 24rpx;
  color: #8B7355;
}

/* ==================== 模块三/四/五：内容模块 ==================== */
.content-section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 板块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2C2C2C;
  margin-bottom: 16rpx;
  display: block;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: linear-gradient(to right, #D4A574, transparent);
  margin-bottom: 24rpx;
}

/* 内容文本 */
.content-text {
  font-size: 28rpx;
  color: #3D3D3D;
  line-height: 1.8;
  text-align: justify;
  display: block;
}

/* ==================== 模块五：章节目录 ==================== */
.chapter-list {
  margin-top: 8rpx;
}

/* 章节条目 */
.chapter-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0EBE3;
}

.chapter-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.chapter-item:first-child {
  padding-top: 0;
}

/* 章节标题 */
.chapter-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #2C2C2C;
  margin-bottom: 12rpx;
  display: block;
}

/* 章节描述 */
.chapter-desc {
  font-size: 26rpx;
  color: #6B6560;
  line-height: 1.8;
  display: block;
}

/* 底部留白 */
.bottom-space {
  height: 60rpx;
}
