.page-container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  padding: 30rpx;
}

.video-card {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 20rpx;
}

.video-wrapper {
  position: relative;
  width: 100%;
  height: 400rpx;
}

.video-player {
  width: 100%;
  height: 100%;
}

.video-info {
  padding-top: 16rpx;
}

.video-title {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.video-meta {
  display: flex;
  flex-direction: row;
}

.meta-item {
  font-size: 26rpx;
  color: #999;
  margin-right: 20rpx;
}