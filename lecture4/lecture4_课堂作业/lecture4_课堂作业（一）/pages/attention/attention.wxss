.page-container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  padding: 30rpx;
}

.follow-card {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 20rpx;
}

.follow-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.follow-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  display: block;
}

.follow-images {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.follow-img {
  width: 33.33%;
  height: 200rpx;
  box-sizing: border-box;
  padding: 4rpx;
}

.follow-actions {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
}

.action-item {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 26rpx;
  color: #999;
}