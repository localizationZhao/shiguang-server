/**
 * pay.wxss - 微信支付页面样式文件
 * 功能：书籍购买支付界面样式
 */

/* 页面容器 */
.container {
  padding: 20rpx;
  padding-bottom: 180rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 商品信息展示区 */
.product-section {
  margin-bottom: 20rpx;
}

.product-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.product-image {
  width: 180rpx;
  height: 240rpx;
  border-radius: 8rpx;
  background-color: #f0f0f0;
  margin-right: 30rpx;
}

.product-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.product-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.price-label {
  font-size: 28rpx;
  color: #999;
}

.price-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B35;
}

/* 支付参数展示区 */
.params-section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.params-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.param-item {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.param-item:last-child {
  border-bottom: none;
}

.param-label {
  font-size: 26rpx;
  color: #999;
  width: 160rpx;
}

.param-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

/* 签名说明 */
.sign-info {
  background-color: #fffbe8;
  border-radius: 12rpx;
  padding: 20rpx;
  border: 1rpx solid #ffe58f;
}

.sign-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #d48806;
  margin-bottom: 10rpx;
}

.sign-text {
  font-size: 24rpx;
  color: #ad8b00;
  word-break: break-all;
}

/* 支付结果展示区 */
.result-section {
  margin-bottom: 20rpx;
}

.result-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
}

.result-card.success {
  border: 2rpx solid #07c160;
  background-color: #f6ffed;
}

.result-card.fail {
  border: 2rpx solid #fa5151;
  background-color: #fff2f0;
}

.result-icon {
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.result-card.success .result-title {
  color: #07c160;
}

.result-card.fail .result-title {
  color: #fa5151;
}

.result-message {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

/* 订单信息 */
.order-info {
  background-color: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.order-text {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

/* 底部支付按钮（固定定位） */
.pay-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eee;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.pay-button {
  width: 100%;
  height: 88rpx;
  background-color: #FF6B35;
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-button::after {
  border: none;
}

.pay-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}