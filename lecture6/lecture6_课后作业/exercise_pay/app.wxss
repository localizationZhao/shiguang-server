/**
 * app.wxss - 全局样式文件
 * 项目：课后作业一：微信支付功能实现
 */

/* 全局容器样式 */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 基础字体样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  background-color: #f8f8f8;
}

/* 通用按钮样式 */
.btn-primary {
  background-color: #FF6B35;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 20rpx 40rpx;
}

.btn-primary:active {
  background-color: #e55a2b;
}

/* 结果展示样式 */
.result-box {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  border: 1rpx solid #eee;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.result-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 状态提示样式 */
.status-success {
  color: #07c160;
}

.status-fail {
  color: #fa5151;
}