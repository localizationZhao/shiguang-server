/* 菜谱详情 - 像素便签风 */

.detail-page{min-height:100vh;padding:24rpx 24rpx 120rpx;max-width:750rpx;margin:0 auto;box-sizing:border-box}

/* 封面 */
.cover-wrap{margin:0 -24rpx 20rpx;overflow:hidden}
.cover-img{width:100%;aspect-ratio:4/3;display:block;object-fit:cover}
.cover-placeholder{width:100%;aspect-ratio:4/3;background:linear-gradient(160deg,var(--hl),#ffd4e8 50%,#ffb8d0);display:flex;align-items:center;justify-content:center}
.cover-emoji{font-size:120rpx}

/* 卡片 */
.card{background:var(--bg);padding:24rpx;margin-bottom:16rpx;
  box-shadow:var(--border) 0 var(--hl),var(--neg-border) 0 var(--hl),0 calc(var(--neg-border)) var(--hl),0 var(--border) var(--hl),calc(var(--border)*2) 0 var(--hl),calc(var(--neg-border)*2) 0 var(--hl),0 calc(var(--neg-border)*2) var(--hl),0 calc(var(--border)*2) var(--hl),0 0 0 var(--border) var(--hl),0 0 0 calc(var(--border)*2) #fff,calc(var(--border)*2) 0 0 var(--border) #fff,calc(var(--neg-border)*2) 0 0 var(--border) #fff,0 calc(var(--neg-border)*2) 0 var(--border) #fff,0 calc(var(--border)*2) 0 var(--border) #fff)}

/* 信息 */
.info-name{font-size:36rpx;font-weight:800;color:#3f2c15;line-height:1.3;word-break:break-all;display:block;margin-bottom:14rpx}
.info-tags{display:flex;flex-wrap:wrap;gap:8rpx;margin-bottom:14rpx}
.tag{font-size:20rpx;padding:4rpx 14rpx;border:2rpx solid var(--hl);color:rgba(63,44,21,0.5)}.tag.primary{background:var(--hl);color:var(--bg)}
.info-price-row{display:flex;align-items:baseline;gap:12rpx}
.info-price{font-size:40rpx;font-weight:800;color:var(--hl);max-width:400rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.info-price.free{font-size:24rpx;color:rgba(63,44,21,0.4);font-weight:400}
.info-date{font-size:22rpx;color:rgba(63,44,21,0.4)}

/* 操作按钮 */
.action-row{display:flex}
.action-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:6rpx;padding:16rpx 0}.action-item:active{background:rgba(255,163,203,0.06)}
.action-icon{font-size:40rpx}.action-label{font-size:22rpx;color:rgba(63,44,21,0.5);font-weight:500}

/* 食材清单 */
.section-hd{font-size:28rpx;font-weight:700;color:#3f2c15;font-family:-apple-system,'PingFang SC','Helvetica Neue',sans-serif;display:block;margin-bottom:16rpx}
.ing-list{background:rgba(255,255,255,0.5);border:2rpx solid var(--hl);overflow:hidden}
.ing-row{display:flex;align-items:center;justify-content:space-between;padding:18rpx 20rpx;border-bottom:2rpx solid rgba(0,0,0,0.05)}
.ing-row:last-child{border-bottom:none}
.ing-left{display:flex;align-items:center;gap:10rpx;flex:1;min-width:0}
.ing-cat{font-size:18rpx;background:rgba(255,163,203,0.1);color:var(--hl);padding:2rpx 10rpx;border:1rpx solid var(--hl);white-space:nowrap}
.ing-name{font-size:26rpx;color:#3f2c15;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ing-amount{font-size:24rpx;color:rgba(63,44,21,0.5);margin-left:12rpx;white-space:nowrap}

/* 步骤 */
.step-list{display:flex;flex-direction:column;gap:16rpx}
.step-row{display:flex;gap:16rpx}
.step-num{width:44rpx;height:44rpx;background:var(--hl);color:var(--bg);display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:700;flex-shrink:0}
.step-body{flex:1;background:rgba(255,255,255,0.5);border:2rpx solid var(--hl);padding:18rpx 20rpx}
.step-text{font-size:26rpx;line-height:1.8;color:#3f2c15}
.step-img{width:100%;height:240rpx;border:2rpx solid var(--hl);margin-top:12rpx}

/* 参考 */
.ref-text{font-size:26rpx;color:rgba(63,44,21,0.6);line-height:1.7}

/* 空状态 */
.empty-state{height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20rpx}
.empty-text{font-size:28rpx;color:rgba(63,44,21,0.4)}
.no-data{text-align:center;padding:40rpx;color:rgba(63,44,21,0.4);font-size:24rpx}
/* 分享导出弹窗 — 像素风绿色主题 */
.export-overlay {
  display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45); z-index: 1000;
  justify-content: center; align-items: center;
  padding: 0 40rpx;
}
.export-overlay.show { display: flex; }

.export-window {
  background: #ffecda; width: 100%; max-width: 520rpx; max-height: 70vh; overflow-y: auto;
  box-shadow:
    4rpx 0 #6de192, -4rpx 0 #6de192,
    0 -4rpx #6de192, 0 4rpx #6de192,
    8rpx 0 #6de192, -8rpx 0 #6de192,
    0 -8rpx #6de192, 0 8rpx #6de192,
    0 0 0 4rpx #6de192,
    0 0 0 8rpx #fff,
    8rpx 0 0 4rpx #fff, -8rpx 0 0 4rpx #fff,
    0 -8rpx 0 4rpx #fff, 0 8rpx 0 4rpx #fff;
  animation: fadeUp .25s ease;
}

.export-hd {
  background: #6de192; color: #ffecda;
  padding: 10rpx 30rpx; text-align: center;
  font-family: 'Courier New', monospace;
  font-weight: bold; font-size: 28rpx;
  position: relative;
  box-shadow: 2rpx 0 #6de192, -2rpx 0 #6de192, 0 -2rpx #6de192, -2rpx 2rpx #6de192, 2rpx 2rpx #6de192;
}

.export-title { font-family: 'Courier New', monospace; }

.export-close {
  position: absolute; top: 0; right: 0;
  padding: 0 10rpx; color: #ffecda;
  font-family: 'Courier New', monospace; font-size: 36rpx;
  font-weight: bold;
  text-shadow:
    2rpx 0 0 #6de192,
    -2rpx 0 0 #6de192,
    0 2rpx 0 #6de192,
    0 -2rpx 0 #6de192;
}

.export-bd { background: #ffecda; margin-top: 2rpx; padding: 4rpx 0; }

.ex-menu-item {
  display: flex; align-items: center; justify-content: center; gap: 16rpx;
  padding: 20rpx 24rpx;
  font-family: 'Courier New', monospace; font-size: 26rpx;
  color: rgba(63,44,21,0.7);
  background: transparent; border: 0; border-bottom: 2rpx solid rgba(109,225,146,0.25);
  width: 100%; text-align: center; border-radius: 0;
  transition: background .12s, color .12s;
  box-sizing: border-box;
}
.ex-menu-item:last-child { border-bottom: none; }
.ex-menu-item:after { border: none; }
.ex-menu-active { background: #6de192 !important; color: #fff !important; border-bottom-color: transparent !important; }

.ex-mi-icon { font-size: 32rpx; width: 40rpx; text-align: center; flex-shrink: 0; }
