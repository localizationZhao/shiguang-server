/* 新建/编辑菜谱 - 像素便签风 */

.page{min-height:100vh;display:flex;flex-direction:column;padding:0 16rpx;gap:8rpx}

/* 步骤指示器 */
.step-indicator{display:flex;align-items:center;justify-content:center;padding:14rpx 24rpx;flex-shrink:0;background:var(--bg);
  box-shadow:var(--border) 0 var(--hl),var(--neg-border) 0 var(--hl),0 calc(var(--neg-border)) var(--hl),0 var(--border) var(--hl)}
.step-dot{width:44rpx;height:44rpx;display:flex;align-items:center;justify-content:center;font-size:22rpx;font-weight:700;background:rgba(255,255,255,0.5);color:rgba(63,44,21,0.4);border:3rpx solid var(--hl)}
.step-dot.active{background:var(--hl);color:var(--bg)}
.step-dot.done{background:#7ee787;color:#fff;border-color:#7ee787}
.step-line{width:48rpx;height:3rpx;background:var(--hl);margin:0 4rpx}
.step-line.done{background:#7ee787}

/* 表单区 */
.form-scroll{flex:1;padding-bottom:110rpx}
.step-content{padding:24rpx;background:var(--bg);margin-bottom:12rpx;
  box-shadow:var(--border) 0 var(--hl),var(--neg-border) 0 var(--hl),0 calc(var(--neg-border)) var(--hl),0 var(--border) var(--hl),calc(var(--border)*2) 0 var(--hl),calc(var(--neg-border)*2) 0 var(--hl),0 calc(var(--neg-border)*2) var(--hl),0 calc(var(--border)*2) var(--hl),0 0 0 var(--border) var(--hl),0 0 0 calc(var(--border)*2) #fff,calc(var(--border)*2) 0 0 var(--border) #fff,calc(var(--neg-border)*2) 0 0 var(--border) #fff,0 calc(var(--neg-border)*2) 0 var(--border) #fff,0 calc(var(--border)*2) 0 var(--border) #fff)}
.step-title{font-size:28rpx;font-weight:700;color:#3f2c15;display:block;margin-bottom:14rpx;font-family:-apple-system,'PingFang SC','Helvetica Neue',sans-serif}
.step-hint{font-size:20rpx;color:rgba(63,44,21,0.4);display:block;margin-bottom:18rpx}

/* 表单元素 */
.form-group{margin-bottom:18rpx}
.form-label{font-size:24rpx;font-weight:600;color:#3f2c15;margin-bottom:8rpx;display:block}
.form-input{width:100%;height:72rpx;line-height:1.5;padding:0 18rpx;border:3rpx solid var(--hl);font-size:26rpx;background:rgba(255,255,255,0.5);color:#3f2c15;box-sizing:border-box}
.form-input:focus{border-color:var(--hl);background:rgba(255,255,255,0.8)}

/* 标签 */
.tag-picker{display:flex;flex-wrap:wrap;gap:10rpx}
.tag-chip{padding:8rpx 20rpx;font-size:22rpx;background:rgba(255,255,255,0.5);color:rgba(63,44,21,0.5);border:2rpx solid var(--hl)}
.tag-chip.selected{background:var(--hl);color:var(--bg)}
.tag-chip.sm{padding:6rpx 14rpx;font-size:18rpx}
.tag-chip:active{transform:scale(.95)}
.cat-mgr-btn{font-size:20rpx;color:var(--hl);margin-left:10rpx;padding:2rpx 8rpx;border:1rpx solid var(--hl)}
/* 便签颜色选择 */
.color-picker{display:flex;gap:12rpx;flex-wrap:wrap}
.color-chip{width:52rpx;height:52rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 2rpx 8rpx rgba(0,0,0,0.12);transition:transform .15s}
.color-chip:active{transform:scale(.9)}
.color-chip.selected{box-shadow:0 0 0 4rpx #fff,0 0 0 8rpx currentColor}
.color-check{color:#fff;font-size:24rpx;font-weight:700;text-shadow:0 1rpx 2rpx rgba(0,0,0,0.3)}
.cat-input{width:100%;height:60rpx;line-height:1.5;padding:0 12rpx;border:2rpx solid #79bcff;font-size:22rpx;background:rgba(255,255,255,0.5);color:#3f2c15;box-sizing:border-box;margin-bottom:10rpx}

/* 食材块 */
.ingredient-block{background:rgba(255,255,255,0.5);border:2rpx solid var(--hl);padding:16rpx;margin-bottom:12rpx}
.ing-header{display:flex;align-items:center;gap:8rpx;margin-bottom:10rpx;flex-wrap:wrap}
.ing-num{font-size:22rpx;font-weight:700;color:var(--hl)}.ing-cat-picker{display:flex;flex-wrap:wrap;gap:6rpx;flex:1}.ing-remove{font-size:26rpx;color:#f85149;padding:4rpx 10rpx}
.ing-row{display:flex;gap:10rpx}

/* 步骤块 */
.step-block{background:rgba(255,255,255,0.5);border:2rpx solid var(--hl);padding:16rpx;margin-bottom:12rpx}
.step-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10rpx}
.step-badge{width:40rpx;height:40rpx;background:var(--hl);color:var(--bg);display:flex;align-items:center;justify-content:center;font-size:22rpx;font-weight:700}
.step-actions{display:flex;gap:14rpx}.step-btn{font-size:28rpx;padding:4rpx}.step-btn.danger{color:#f85149}
.step-img-area{position:relative;aspect-ratio:4/3;border:2rpx solid var(--hl);overflow:hidden;margin-bottom:10rpx}.step-img-area .step-img{width:100%;height:100%}
.step-img-remove{position:absolute;top:6rpx;right:6rpx;width:32rpx;height:32rpx;background:rgba(0,0,0,0.5);color:#fff;display:flex;align-items:center;justify-content:center;font-size:20rpx}
.step-textarea{min-height:100rpx}

/* 添加按钮 */
.btn-add-row{width:100%;padding:16rpx;border:2rpx dashed var(--hl);font-size:22rpx;color:rgba(63,44,21,0.4);background:transparent;text-align:center}

/* 封面 */
.cover-picker{width:100%;aspect-ratio:4/3;border:3rpx dashed var(--hl);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10rpx;overflow:hidden;background:rgba(255,255,255,0.3)}
.cover-picker.has-img{border-style:solid;padding:0}.cover-picker-icon{font-size:56rpx}
.cover-picker .cover-picker-img{width:100%;height:100%}

/* 预览 */
.preview-card{margin-top:18rpx;padding:24rpx;background:rgba(255,255,255,0.5);border:2rpx solid var(--hl);text-align:center}
.preview-name{font-size:32rpx;font-weight:700;color:#3f2c15;display:block;margin-bottom:10rpx}
.preview-meta{display:flex;align-items:center;justify-content:center;gap:14rpx;margin-bottom:10rpx}
.preview-price{font-size:36rpx;font-weight:800;color:var(--hl)}.preview-price.free{font-size:22rpx;color:rgba(63,44,21,0.4);font-weight:400}
.preview-stats{font-size:22rpx;color:rgba(63,44,21,0.4)}

/* 底部栏 */
/* ===== 底部操作栏 - 橙色像素风 ===== */
.bottom-bar{position:fixed;bottom:0;left:0;right:0;z-index:1000;display:flex;align-items:center;gap:16rpx;padding:18rpx 24rpx;padding-bottom:calc(18rpx + env(safe-area-inset-bottom));background:#ffb37c;border-top:4rpx solid #e8985a;
  box-shadow:var(--border) 0 #e8985a,var(--neg-border) 0 #e8985a,0 calc(var(--neg-border)) #e8985a,0 var(--border) #e8985a,calc(var(--border)*2) 0 #e8985a,calc(var(--neg-border)*2) 0 #e8985a,0 calc(var(--neg-border)*2) #e8985a,0 calc(var(--border)*2) #e8985a}
.btn-draft{padding:18rpx 20rpx;background:#fff;color:#e85d3a;border:3rpx solid #e8985a;font-size:24rpx;font-weight:800;white-space:nowrap;font-family:monospace;box-shadow:4rpx 4rpx 0 #e8985a}
.btn-draft:active{transform:translate(2rpx,2rpx);box-shadow:2rpx 2rpx 0 #e8985a}
.bottom-nav{flex:1;display:flex;gap:16rpx}
.btn-nav{flex:1;padding:18rpx;font-size:26rpx;font-weight:800;border:none;font-family:monospace;background:#fff;color:#e85d3a;border:3rpx solid #e8985a;box-shadow:4rpx 4rpx 0 #e8985a}.btn-primary{flex:1;padding:18rpx 24rpx;background:#fff;color:#e85d3a;font-size:26rpx;font-weight:800;border:3rpx solid #e8985a;box-shadow:4rpx 4rpx 0 #e8985a;font-family:monospace}
.btn-nav:active,.btn-primary:active,.btn-draft:active{transform:translate(2rpx,2rpx);box-shadow:2rpx 2rpx 0 #e8985a}

/* 分类管理蓝色便签 */
.cat-note{background:var(--bg);width:280rpx;max-height:70vh;overflow-y:auto;animation:fadeUp .25s ease;
  box-shadow:var(--border) 0 #79bcff,var(--neg-border) 0 #79bcff,0 calc(var(--neg-border)) #79bcff,0 var(--border) #79bcff,calc(var(--border)*2) 0 #79bcff,calc(var(--neg-border)*2) 0 #79bcff,0 calc(var(--neg-border)*2) #79bcff,0 calc(var(--border)*2) #79bcff,0 0 0 var(--border) #79bcff,0 0 0 calc(var(--border)*2) #fff,calc(var(--border)*2) 0 0 var(--border) #fff,calc(var(--neg-border)*2) 0 0 var(--border) #fff,0 calc(var(--neg-border)*2) 0 var(--border) #fff,0 calc(var(--border)*2) 0 var(--border) #fff)}
.cat-note-hd{background:#79bcff;color:var(--bg);padding:8rpx 20rpx;text-align:center;font-weight:700;font-size:24rpx;position:relative}
.cat-note-hd .modal-close{position:absolute;right:4rpx;top:2rpx}
.cat-note-bd{padding:10rpx 16rpx 16rpx}
.cat-note-item{display:flex;align-items:center;padding:10rpx 0;border-bottom:1rpx solid rgba(0,0,0,0.05);gap:8rpx}
.cat-note-name{flex:1;font-size:24rpx;color:#3f2c15;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cat-note-acts{display:flex;gap:10rpx;font-size:22rpx;flex-shrink:0}
.cat-note-add{padding:8rpx 0;background:#79bcff;color:var(--bg);border:none;font-size:20rpx;font-weight:700;text-align:center;width:100%;margin-top:8rpx}
