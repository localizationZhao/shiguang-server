<!-- DIY 自制菜谱页面 -->
<navigation-bar title="DIY 自制菜谱" color="#1a1a2e" background="rgba(255,255,255,0.85)" back="{{false}}"></navigation-bar>

<view class="page">
  <!-- 左右分栏布局 -->
  <view class="diy-layout">

    <!-- ===== 左侧分类栏 ===== -->
    <scroll-view class="cat-sidebar" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        class="cat-item {{activeCat === item.name ? 'active' : ''}}"
        style="{{activeCat === item.name ? 'background:#fce4ec;color:#d4809a;border-color:#f5c8d8;box-shadow:3rpx 3rpx 0 #e8c0d0' : ''}}"
        wx:for="{{categories}}"
        wx:key="name"
        data-cat="{{item.name}}"
        bindtap="selectCat">
        <text>{{item.name}}</text>
      </view>

      <!-- 管理分类按钮 -->
      <view class="cat-manage-btn" bindtap="openCatMenu">
        <text>⚙️ 管理</text>
      </view>

    </scroll-view>

    <!-- ===== 右侧主内容区 ===== -->
    <view class="diy-content">

      <!-- 搜索栏 -->
      <view class="diy-search-bar">
        <view class="search-input-wrap">
          <text class="search-icon">🔍</text>
          <input placeholder="搜索我的菜谱..." value="{{searchKeyword}}" bindinput="onSearchInput" bindconfirm="doSearch" confirm-type="search"/>
          <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
          <text class="search-go" bindtap="doSearch">🔍</text>
        </view>

      </view>


      <!-- 顶部操作栏 -->
      <view class="diy-top-bar">
        <view class="category-title">
          <view class="cat-text-row">
            <text class="cat-emoji">{{activeCat === '荤菜' ? '🥩' : activeCat === '素菜' ? '🥬' : activeCat === '凉菜' ? '🥒' : activeCat === '汤羹' ? '🍲' : activeCat === '主食' ? '🍚' : activeCat === '甜点' ? '🍰' : activeCat === '酒水' ? '🍷' : '🍽️'}}</text>
            <text class="cat-name">{{activeCat}}</text>
          </view>

          <view class="cat-underline"></view>

        </view>

        <button class="btn-new-recipe" bindtap="createRecipe">＋ 新建菜谱</button>
      </view>


      <!-- 菜谱卡片网格 -->
      <scroll-view class="recipe-grid" scroll-y enhanced show-scrollbar="{{false}}" wx:if="{{!isEmpty}}">
        <view
          class="recipe-card {{isManageMode && selectedIds.indexOf(item.id) >= 0 ? 'selected' : ''}}"
          style="--hl:{{item.color}};--hl-bg:{{item.color}}22"
          wx:for="{{filteredRecipes}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="viewDetail"
          bindlongpress="longPressRecipe">
          <!-- 管理模式的勾选标记 -->
          <view class="card-check" wx:if="{{isManageMode}}">
            <view class="check-circle {{selectedIds.indexOf(item.id) >= 0 ? 'checked' : ''}}">
              <text wx:if="{{selectedIds.indexOf(item.id) >= 0}}">✓</text>
            </view>

          </view>

          <!-- 封面 -->
          <view class="recipe-card-img">
            <image class="card-cover" wx:if="{{item.coverImg}}" src="{{item.coverImg}}" mode="aspectFill"></image>
            <text wx:else class="cover-emoji">{{item.coverEmoji || '🍽️'}}</text>
          </view>

          <!-- 信息 -->
          <view class="recipe-card-info">
            <text class="recipe-card-name">{{item.name}}</text>
            <text class="recipe-card-price {{item.price ? '' : 'free'}}">{{item.price ? '¥' + item.price : '免费'}}</text>
            <text class="recipe-card-cat">{{item.category}}</text>
          </view>

        </view>

      </scroll-view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{isEmpty}}">
        <view class="empty-card">
          <text class="empty-emoji">🍳</text>
          <text class="empty-title-pixel">快来做你的第一道菜吧！</text>
          <text class="empty-sub">点击上方 新建菜谱 开始创作 ~</text>
          <button class="empty-btn" bindtap="createRecipe">＋ 创建第一道菜</button>
        </view>
      </view>


    </view>

  </view>

</view>


<!-- ===== 长按上下文菜单 ===== -->
<view class="modal-overlay {{showContextMenu ? 'show' : ''}}" bindtap="closeContextMenu">
  <view class="modal-sheet" catchtap="preventClose">
    <view class="modal-header">
      <text class="modal-title">{{contextRecipe ? contextRecipe.name : ''}}</text>
      <view class="modal-close" bindtap="closeContextMenu">✕</view>

    </view>

    <view class="modal-body context-menu">
      <view class="context-item" bindtap="editRecipe">
        <text class="context-icon">✏️</text>
        <text>编辑菜谱</text>
      </view>

      <view class="context-item" bindtap="shelfToRestaurant">
        <text class="context-icon">🏪</text>
        <text>上架至餐厅</text>
      </view>

      <view class="context-item danger" bindtap="confirmDeleteRecipe">
        <text class="context-icon">🗑️</text>
        <text>删除菜谱</text>
      </view>

    </view>

  </view>

</view>


<!-- ===== 分类管理弹窗 - 便签样式 ===== -->
<view class="modal-overlay {{showCatMenu ? 'show' : ''}}" bindtap="closeCatMenu">
  <view class="cat-note" catchtap="preventClose">
    <view class="cat-note-hd"><text>分类</text><view class="modal-close" bindtap="closeCatMenu">✕</view></view>
    <view class="cat-note-bd">
      <view class="cat-note-item" wx:for="{{categories}}" wx:key="name">
        <text class="cat-note-name">{{item.name}}</text>
        <view class="cat-note-acts">
          <text data-cat="{{item}}" bindtap="showEditCatDialog">✏️</text>
          <text data-cat="{{item}}" bindtap="deleteCategory" style="color:#f85149">✕</text>
        </view>
      </view>
      <button class="cat-note-add" bindtap="showAddCatDialog">＋ 新建</button>
    </view>
  </view>
</view>


<!-- ===== 新建分类弹窗 - 蓝色便签 ===== -->
<view class="modal-overlay {{showAddCat ? 'show' : ''}}" bindtap="cancelAddCat">
  <view class="cat-note cat-note-blue" catchtap="preventClose">
    <view class="cat-note-hd"><text>新建</text><view class="modal-close" bindtap="cancelAddCat">✕</view></view>
    <view class="cat-note-bd">
      <input class="cat-input" placeholder="起个名" value="{{newCatName}}" bindinput="onNewCatInput" maxlength="4"/>
      <button class="cat-note-add" bindtap="confirmAddCat">确认</button>
    </view>
  </view>
</view>

<!-- ===== 编辑分类弹窗 - 蓝色便签 ===== -->
<view class="modal-overlay {{showEditCat ? 'show' : ''}}" bindtap="cancelEditCat">
  <view class="cat-note cat-note-blue" catchtap="preventClose">
    <view class="cat-note-hd"><text>改名</text><view class="modal-close" bindtap="cancelEditCat">✕</view></view>
    <view class="cat-note-bd">
      <input class="cat-input" placeholder="新名字" value="{{editCatName}}" bindinput="onEditCatInput" maxlength="4"/>
      <button class="cat-note-add" bindtap="confirmEditCat">确认</button>
    </view>
  </view>
</view>


<!-- ===== 删除确认弹窗 ===== -->
<view class="modal-overlay {{showDeleteConfirm ? 'show' : ''}}" bindtap="cancelDelete">
  <view class="modal-sheet" catchtap="preventClose">
    <view class="modal-header">
      <text class="modal-title">确认删除</text>
      <view class="modal-close" bindtap="cancelDelete">✕</view>

    </view>

    <view class="modal-body" style="text-align:center">
      <text style="font-size:40px;display:block;margin-bottom:12px">⚠️</text>
      <text style="font-size:15px;color:#1a1a2e;display:block;margin-bottom:8px">确定删除"{{deleteTargetName}}"吗？</text>
      <text style="font-size:12px;color:rgba(26,26,46,0.45)">删除后不可恢复</text>
      <view style="display:flex;gap:12px;margin-top:20px">
        <button class="btn-outline" style="flex:1" bindtap="cancelDelete">取消</button>
        <button class="btn-primary" style="flex:1;background:#e74c3c" bindtap="doDeleteRecipe">确认删除</button>
      </view>

    </view>

  </view>

</view>


<!-- ===== 采购清单弹窗 ===== -->
<view class="modal-overlay {{showShoppingList ? 'show' : ''}}" bindtap="closeShoppingList">
  <view class="modal-sheet" catchtap="preventClose">
    <view class="modal-header">
      <text class="modal-title">📋 采购清单</text>
      <view class="modal-close" bindtap="closeShoppingList">✕</view>

    </view>

    <view class="modal-body">
      <view wx:if="{{shoppingItems.length === 0}}" style="text-align:center;padding:40px">
        <text style="color:rgba(26,26,46,0.45)">没有食材</text>
      </view>

      <view class="shopping-item" wx:for="{{shoppingItems}}" wx:key="name">
        <text class="shopping-check">☐</text>
        <view class="shopping-info">
          <text class="shopping-name">{{item.name}}</text>
          <text class="shopping-amount">{{item.amount}}</text>
        </view>

        <text class="shopping-count" wx:if="{{item.count > 1}}">x{{item.count}}</text>
      </view>

      <button class="btn-outline" style="width:100%;margin-top:12px" bindtap="copyShoppingList">📋 复制清单</button>
    </view>

  </view>

<!-- 飘落 -->
<view class="float-food" style="left:10%;animation-delay:0s">🍳</view>
<view class="float-food" style="left:40%;animation-delay:-6s">🥢</view>
<view class="float-food" style="left:70%;animation-delay:-12s">🍜</view>
</view>

