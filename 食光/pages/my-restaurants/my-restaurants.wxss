.page{height:100vh;padding:12rpx 16rpx;box-sizing:border-box}
.section-label{font-size:24rpx;color:rgba(63,44,21,0.35);padding:16rpx 0 8rpx;font-weight:700}
.empty{text-align:center;padding:30rpx;font-size:24rpx;color:rgba(63,44,21,0.3)}
.rest-card{display:flex;align-items:center;padding:20rpx;margin-bottom:10rpx;background:#ffecda;border-radius:8rpx;
  box-shadow:3rpx 3rpx 0 rgba(0,0,0,0.05),0 0 0 2rpx #fff,0 0 0 4rpx #ffa3cb}
.rc-info{flex:1}
.rc-name{font-size:28rpx;font-weight:700;color:#3f2c15;display:block}
.rc-code{font-size:22rpx;color:rgba(63,44,21,0.35);display:block;margin-top:4rpx}
.rc-meta{font-size:22rpx;color:rgba(63,44,21,0.4);display:block}
.rc-badge{padding:6rpx 14rpx;border-radius:4rpx;font-size:20rpx;font-weight:700}
.rc-badge.owner{background:#ffa3cb;color:#fff}
.rc-badge.customer{background:#79bcff;color:#fff}
.goto-btn{margin-top:20rpx;text-align:center;padding:16rpx;background:#ffa3cb;color:#fff;font-size:28rpx;font-weight:700;border-radius:8rpx;
  box-shadow:3rpx 3rpx 0 #d43d7e}
