<navigation-bar title="我的收藏" color="#1a1a2e" background="rgba(255,255,255,0.85)" back="{{true}}"></navigation-bar>
<scroll-view class="page" scroll-y wx:if="{{favorites.length>0}}"><view class="glass" wx:for="{{favorites}}" wx:key="id" data-id="{{item.id}}" bindtap="viewDetail" style="display:flex;align-items:center;gap:12px;margin:8px"><text style="font-size:32px">{{item.coverEmoji}}</text><view style="flex:1"><text style="font-weight:600;display:block">{{item.name}}</text><text style="font-size:12px;color:rgba(26,26,46,0.55)">{{item.category}}</text></view><text bindtap="removeFav" data-id="{{item.id}}" style="font-size:20px">❤️</text></view></scroll-view>
<view class="empty-state" wx:else><text style="font-size:64px">💔</text><text style="color:rgba(26,26,46,0.45)">还没有收藏菜谱</text></view>