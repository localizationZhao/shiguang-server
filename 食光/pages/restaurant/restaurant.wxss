/* 发布感受便签 */
.feed-note{background:#ffecda;width:540rpx;max-height:75vh;overflow-y:auto;animation:popIn .25s ease;
  box-shadow:var(--border) 0 var(--hl),var(--neg-border) 0 var(--hl),0 calc(var(--neg-border)) var(--hl),0 var(--border) var(--hl),calc(var(--border)*2) 0 var(--hl),calc(var(--neg-border)*2) 0 var(--hl),0 calc(var(--neg-border)*2) var(--hl),0 calc(var(--border)*2) var(--hl),0 0 0 var(--border) var(--hl),0 0 0 calc(var(--border)*2) #fff,calc(var(--border)*2) 0 0 var(--border) #fff,calc(var(--neg-border)*2) 0 0 var(--border) #fff,0 calc(var(--neg-border)*2) 0 var(--border) #fff,0 calc(var(--border)*2) 0 var(--border) #fff}
.feed-note-hd{background:var(--hl);color:#fff;padding:10rpx 28rpx;text-align:center;font-weight:700;font-size:22rpx;position:relative;font-family:monospace}
.feed-note-hd .modal-close{position:absolute;right:8rpx;top:4rpx;font-size:28rpx;color:#fff}
.feed-note-bd{padding:14rpx 22rpx 18rpx;display:flex;flex-direction:column;gap:10rpx}
.feed-textarea{width:100%;min-height:70rpx;padding:10rpx 14rpx;border:2rpx solid var(--hl);font-size:22rpx;font-family:monospace;background:#fff;box-sizing:border-box;box-shadow:2rpx 2rpx 0 var(--rhl)}
.feed-row{display:flex;flex-direction:column;gap:4rpx}
.feed-row-label{font-size:18rpx;color:rgba(63,44,21,0.35);font-weight:700;font-family:monospace}
.feed-chips{display:flex;flex-wrap:wrap;gap:6rpx}
.feed-chip{padding:6rpx 14rpx;font-size:18rpx;background:#fff;color:rgba(63,44,21,0.5);border:2rpx solid var(--hl);font-family:monospace}
.feed-chip.active{background:var(--hl);color:#fff;font-weight:700}
.feed-input{margin-top:4rpx;width:100%;height:50rpx;padding:0 10rpx;border:2rpx solid var(--hl);font-size:18rpx;font-family:monospace;background:#fff}
.feed-loc-preview{display:flex;flex-direction:column;gap:8rpx;padding:8rpx;background:rgba(255,255,255,0.5);border-radius:8rpx}
.feed-map{width:100%;height:200rpx;border-radius:6rpx}
.feed-loc-text{font-size:22rpx;color:#3f2c15;font-weight:600}
.feed-loc-change{font-size:20rpx;color:var(--hl)}
.feed-action-row{display:flex;gap:10rpx}
.btn-feed-img{flex:1;padding:12rpx;background:#fff;color:var(--hl);border:2rpx solid var(--hl);font-size:20rpx;font-weight:700;font-family:monospace;box-shadow:3rpx 3rpx 0 var(--rhl)}
.btn-feed-post{flex:2;padding:12rpx;background:var(--hl);color:#fff;border:none;font-size:20rpx;font-weight:800;font-family:monospace;box-shadow:3rpx 3rpx 0 var(--rhd)}
.btn-feed-img:active,.btn-feed-post:active{transform:translate(2rpx,2rpx);box-shadow:1rpx 1rpx 0}
