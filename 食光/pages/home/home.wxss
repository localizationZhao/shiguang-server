.flex-1{flex:1;overflow:hidden;padding:0 16rpx}

/* 搜索返回悬浮按钮 */
.search-back-bar{position:fixed;bottom:130rpx;left:0;right:0;z-index:1000;padding:16rpx 24rpx;padding-bottom:calc(16rpx + env(safe-area-inset-bottom));display:flex;justify-content:center;pointer-events:none}
