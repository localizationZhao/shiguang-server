/* ===== 标签便签按钮 ===== */
.pref-tags{display:flex;flex-wrap:wrap;gap:10rpx;flex-shrink:0;padding:4rpx 0}
.pref-tag{
  display:flex;padding:14rpx 20rpx;font-size:32rpx;font-weight:700;
  background:#ffecda;color:var(--thd);border:3rpx solid var(--th);
  box-shadow:3rpx 3rpx 0 var(--thd);
  transition:all .15s;font-family:monospace;align-items:center;justify-content:center;
}
.pref-tag.active{
  background:var(--thl);color:var(--thd);font-weight:800;
  box-shadow:3rpx 3rpx 0 var(--thd);
  z-index:2;
}
.pref-tag-press{transform:translate(2rpx,2rpx);box-shadow:2rpx 2rpx 0 var(--thd) !important}
.pref-tag:active{transform:translate(2rpx,2rpx);box-shadow:2rpx 2rpx 0 var(--thd)}
