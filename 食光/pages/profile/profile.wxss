/* 个人中心 - 便签风 */
.page{height:100vh;padding:12rpx 16rpx 150rpx;box-sizing:border-box}

/* 用户卡片 */
.profile-card{display:flex;align-items:center;gap:20rpx;padding:24rpx;margin-bottom:16rpx;
  background:#ffecda;border-radius:8rpx;
  box-shadow:3rpx 0 #ffa3cb,-3rpx 0 #ffa3cb,0 -3rpx #ffa3cb,0 3rpx #ffa3cb,
    6rpx 0 #d43d7e,-6rpx 0 #d43d7e,0 -6rpx #d43d7e,0 6rpx #d43d7e,
    0 0 0 3rpx #ffa3cb,0 0 0 6rpx #fff,
    6rpx 0 0 3rpx #fff,-6rpx 0 0 3rpx #fff,
    0 -6rpx 0 3rpx #fff,0 6rpx 0 3rpx #fff;}
.pf-avatar-wrap{width:80rpx;height:80rpx;border-radius:50%;background:rgba(255,163,203,0.3);
  display:flex;align-items:center;justify-content:center;flex-shrink:0}
.pf-avatar-em{font-size:44rpx}
.pf-avatar-img{width:100%;height:100%;border-radius:50%}
.pf-info{flex:1;display:flex;flex-direction:column;gap:4rpx}
.pf-nick{font-size:32rpx;font-weight:700;color:#3f2c15}
.pf-id{font-size:22rpx;color:rgba(63,44,21,0.4)}
.pf-birth{font-size:24rpx;color:#3f2c15}
.pf-birth-hint{font-size:22rpx;color:rgba(63,44,21,0.3)}

/* 快捷4宫格 */
.quick-grid{display:grid;grid-template-columns:1fr 1fr;gap:12rpx;margin-bottom:16rpx}
.quick-card{--qc:#ffa3cb;background:#fff;border-radius:8rpx;padding:10rpx;text-align:center;
  box-shadow:2rpx 2rpx 0 var(--qc);border:2rpx solid var(--qc)}
.quick-card:active{transform:translate(1rpx,1rpx);box-shadow:0 0 0 var(--qc)}
.qc-icon{font-size:28rpx;display:block}
.qc-count{font-size:26rpx;font-weight:800;color:var(--qc);display:block}
.qc-title{font-size:20rpx;font-weight:600;color:#3f2c15;display:block}
.qc-desc{font-size:18rpx;color:rgba(63,44,21,0.3);display:block;margin-top:2rpx}

/* 📔 食光日记入口 */
.diary-entry{display:flex;align-items:center;gap:16rpx;padding:20rpx;margin-bottom:12rpx;
  background:#ffecda;border-radius:8rpx;
  box-shadow:3rpx 3rpx 0 rgba(0,0,0,0.05),0 0 0 2rpx #fff,0 0 0 4rpx #ffa3cb}
.diary-entry:active{transform:translate(2rpx,2rpx)}
.de-icon{font-size:44rpx}
.de-info{flex:1}
.de-title{font-size:28rpx;font-weight:700;color:#3f2c15;display:block}
.de-desc{font-size:20rpx;color:rgba(63,44,21,0.35);display:block;margin-top:2rpx}
.de-arrow{font-size:36rpx;color:#ffa3cb}

/* 🍳 烹饪时光 */
.cooking-section{background:#ffecda;border-radius:12rpx;margin-bottom:16rpx;overflow:hidden;
  box-shadow:4rpx 6rpx 12rpx rgba(0,0,0,0.08),0 0 0 2rpx #fff,0 0 0 4rpx #ffa3cb}
.cooking-hd{display:flex;align-items:center;gap:12rpx;padding:20rpx 24rpx;
  background:linear-gradient(135deg,#ffecda,#ffe0c0)}
.cooking-title{font-size:30rpx;font-weight:800;color:#3f2c15;flex:1}
.cooking-count{font-size:24rpx;color:rgba(63,44,21,0.45)}
.cooking-arrow{font-size:22rpx;color:#ffa3cb}
.cooking-bd{max-height:0;overflow:hidden;transition:max-height .3s}
.cooking-bd.show{max-height:600rpx;padding:0 24rpx 20rpx}
.cooking-empty{font-size:24rpx;color:rgba(63,44,21,0.35);padding:20rpx 0;text-align:center}
.cooking-item{display:flex;justify-content:space-between;padding:12rpx 0;border-bottom:1rpx solid rgba(63,44,21,0.08)}
.ci-name{font-size:26rpx;color:#3f2c15;font-weight:600}
.ci-date{font-size:22rpx;color:rgba(63,44,21,0.4)}
.cooking-actions{display:flex;gap:16rpx;margin-top:16rpx}
.cooking-btn{flex:1;text-align:center;padding:14rpx;border-radius:8rpx;font-size:24rpx;font-weight:600;
  background:#ffa3cb;color:#fff;box-shadow:3rpx 3rpx 0 #d43d7e}
.cooking-btn:active{transform:translate(2rpx,2rpx);box-shadow:1rpx 1rpx 0 #d43d7e}
.cooking-btn.sync{background:#79bcff;box-shadow:3rpx 3rpx 0 #5a90d4}

/* 设置区 */
.settings-section{background:#fff;border-radius:10rpx;margin-bottom:16rpx;overflow:hidden;
  box-shadow:0 2rpx 8rpx rgba(0,0,0,0.06)}
.set-item{display:flex;justify-content:space-between;align-items:center;padding:20rpx 24rpx;
  font-size:26rpx;color:#3f2c15;border-bottom:1rpx solid rgba(0,0,0,0.04)}
.set-item:active{background:rgba(0,0,0,0.03)}
.set-item.warn{color:#e74c3c}
.set-arrow{font-size:30rpx;color:rgba(0,0,0,0.2)}

/* 编辑资料弹窗 */
.modal-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.4);z-index:2000;justify-content:center;align-items:center}
.modal-overlay.show{display:flex}
.modal-sheet{width:85%;max-width:600rpx;background:#ffecda;border-radius:12rpx;overflow:hidden;
  box-shadow:4rpx 6rpx 0 rgba(0,0,0,0.1),0 0 0 2rpx #fff,0 0 0 4rpx #ffa3cb}
.modal-hd{display:flex;justify-content:space-between;align-items:center;padding:20rpx 24rpx;background:#ffa3cb;color:#fff;font-weight:700;font-size:28rpx}
.modal-close{font-size:34rpx;padding:4rpx}
.modal-body{padding:24rpx}
.form-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:20rpx}
.form-label{font-size:26rpx;color:#3f2c15;font-weight:600}
.form-input{border:2rpx solid #ffa3cb;padding:10rpx 16rpx;border-radius:6rpx;font-size:26rpx;width:60%;text-align:right}
.form-picker{border:2rpx solid #ffa3cb;padding:10rpx 16rpx;border-radius:6rpx;font-size:26rpx;color:#3f2c15}
.btn-save{width:100%;padding:16rpx;background:#ffa3cb;color:#fff;font-size:28rpx;font-weight:700;border-radius:8rpx;
  box-shadow:3rpx 3rpx 0 #d43d7e;margin-top:10rpx}
.btn-save:active{transform:translate(2rpx,2rpx);box-shadow:1rpx 1rpx 0 #d43d7e}

/* 小鸟设置 */
.bird-section{background:#fff;border-radius:10rpx;margin-bottom:16rpx;overflow:hidden;
  box-shadow:0 2rpx 8rpx rgba(0,0,0,0.06);padding:20rpx}
.bird-hd{margin-bottom:12rpx}
.bird-title{font-size:28rpx;font-weight:700;color:#3f2c15}
.bird-modes{display:flex;gap:12rpx;margin-bottom:12rpx}
.bird-mode{flex:1;text-align:center;padding:14rpx;border-radius:8rpx;font-size:24rpx;
  border:2rpx solid rgba(0,0,0,0.08);color:rgba(63,44,21,0.5)}
.bird-mode.active{border-color:#ffa3cb;background:rgba(255,163,203,0.1);color:#3f2c15;font-weight:700}
.bird-pages{display:flex;flex-wrap:wrap;gap:10rpx}
.bird-page{display:flex;align-items:center;gap:8rpx;padding:10rpx 18rpx;border-radius:6rpx;
  font-size:24rpx;border:2rpx solid rgba(0,0,0,0.06);color:rgba(63,44,21,0.4)}
.bird-page.on{border-color:#79bcff;background:rgba(121,188,255,0.08);color:#3f2c15;font-weight:600}
.bp-check{color:#79bcff;font-weight:700;font-size:22rpx}
