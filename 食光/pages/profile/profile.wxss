/* 个人中心 - 像素便签风 */

.page{height:100vh;padding:0 16rpx;padding-bottom:150rpx}

/* ===== 用户卡片 ===== */
.user-card{display:flex;align-items:center;gap:16rpx;margin-top:8rpx;padding:20rpx;background:var(--bg);
  box-shadow:var(--border) 0 var(--hl),var(--neg-border) 0 var(--hl),0 calc(var(--neg-border)) var(--hl),0 var(--border) var(--hl),calc(var(--border)*2) 0 var(--hl),calc(var(--neg-border)*2) 0 var(--hl),0 calc(var(--neg-border)*2) var(--hl),0 calc(var(--border)*2) var(--hl),0 0 0 var(--border) var(--hl),0 0 0 calc(var(--border)*2) #fff,calc(var(--border)*2) 0 0 var(--border) #fff,calc(var(--neg-border)*2) 0 0 var(--border) #fff,0 calc(var(--neg-border)*2) 0 var(--border) #fff,0 calc(var(--border)*2) 0 var(--border) #fff)}
.user-avatar{width:64rpx;height:64rpx;border:3rpx solid var(--hl);display:flex;align-items:center;justify-content:center;font-size:36rpx;overflow:hidden}
.avatar-img{width:100%;height:100%}
.user-info{flex:1}.user-nick{font-size:32rpx;font-weight:800;color:#3f2c15;font-family:-apple-system,'PingFang SC','Helvetica Neue',sans-serif;display:block}.user-id{font-size:20rpx;color:rgba(63,44,21,0.4);display:block}
.user-edit{font-size:22rpx;color:var(--hl);font-weight:600}

/* ===== 数据统计 ===== */
.stats-row{display:flex;text-align:center;padding:20rpx;margin-bottom:12rpx;background:var(--bg);
  box-shadow:var(--border) 0 var(--hl),var(--neg-border) 0 var(--hl),0 calc(var(--neg-border)) var(--hl),0 var(--border) var(--hl),calc(var(--border)*2) 0 var(--hl),calc(var(--neg-border)*2) 0 var(--hl),0 calc(var(--neg-border)*2) var(--hl),0 calc(var(--border)*2) var(--hl),0 0 0 var(--border) var(--hl),0 0 0 calc(var(--border)*2) #fff,calc(var(--border)*2) 0 0 var(--border) #fff,calc(var(--neg-border)*2) 0 0 var(--border) #fff,0 calc(var(--neg-border)*2) 0 var(--border) #fff,0 calc(var(--border)*2) 0 var(--border) #fff)}
.stat-item{flex:1;display:flex;flex-direction:column;gap:4rpx}
.stat-num{font-size:36rpx;font-weight:800;color:var(--hl);font-family:-apple-system,'PingFang SC','Helvetica Neue',sans-serif}
.stat-label{font-size:20rpx;color:rgba(63,44,21,0.4)}
.stat-divider{width:2rpx;background:var(--hl);margin:4rpx 0}

/* ===== 菜单 ===== */
.menu-section{padding:4rpx 0;margin-bottom:12rpx;background:var(--bg);
  box-shadow:var(--border) 0 var(--hl),var(--neg-border) 0 var(--hl),0 calc(var(--neg-border)) var(--hl),0 var(--border) var(--hl),calc(var(--border)*2) 0 var(--hl),calc(var(--neg-border)*2) 0 var(--hl),0 calc(var(--neg-border)*2) var(--hl),0 calc(var(--border)*2) var(--hl),0 0 0 var(--border) var(--hl),0 0 0 calc(var(--border)*2) #fff,calc(var(--border)*2) 0 0 var(--border) #fff,calc(var(--neg-border)*2) 0 0 var(--border) #fff,0 calc(var(--neg-border)*2) 0 var(--border) #fff,0 calc(var(--border)*2) 0 var(--border) #fff)}
.section-label{font-size:22rpx;color:rgba(63,44,21,0.3);padding:10rpx 20rpx 4rpx;display:block}
.menu-item{display:flex;align-items:center;padding:16rpx 20rpx;border-bottom:2rpx solid rgba(0,0,0,0.05);gap:14rpx}
.menu-item:last-child{border-bottom:none}
.menu-icon{font-size:28rpx;width:32rpx;text-align:center}
.menu-title{flex:1;font-size:26rpx;color:#3f2c15;font-family:-apple-system,'PingFang SC','Helvetica Neue',sans-serif}
.menu-badge{background:var(--hl);color:var(--bg);font-size:18rpx;padding:2rpx 10rpx;font-weight:600}
.menu-arrow{font-size:24rpx;color:var(--hl)}
