/* 个人中心 - 便签风 */
.page{height:100vh;padding:12rpx 16rpx 150rpx;box-sizing:border-box}

/* ===== 像素便签通用边框 ===== */
.sticky-box{background:#ffecda;position:relative;
  box-shadow:3rpx 0 #FF9A56,-3rpx 0 #FF9A56,0 -3rpx #FF9A56,0 3rpx #FF9A56,
    6rpx 0 #FF9A56,-6rpx 0 #FF9A56,0 -6rpx #FF9A56,0 6rpx #FF9A56,
    0 0 0 3rpx #FF9A56,0 0 0 6rpx #fff,
    6rpx 0 0 3rpx #fff,-6rpx 0 0 3rpx #fff,
    0 -6rpx 0 3rpx #fff,0 6rpx 0 3rpx #fff}

/* 用户卡片 */
.profile-card{display:flex;align-items:center;gap:20rpx;padding:24rpx;margin-bottom:16rpx;
  background:#ffecda;position:relative;
  box-shadow:3rpx 0 #FF9A56,-3rpx 0 #FF9A56,0 -3rpx #FF9A56,0 3rpx #FF9A56,
    6rpx 0 #FF9A56,-6rpx 0 #FF9A56,0 -6rpx #FF9A56,0 6rpx #FF9A56,
    0 0 0 3rpx #FF9A56,0 0 0 6rpx #fff,
    6rpx 0 0 3rpx #fff,-6rpx 0 0 3rpx #fff,
    0 -6rpx 0 3rpx #fff,0 6rpx 0 3rpx #fff}
.pf-avatar-wrap{width:80rpx;height:80rpx;border-radius:50%;background:rgba(255,163,203,0.3);
  display:flex;align-items:center;justify-content:center;flex-shrink:0}
.pf-avatar-em{font-size:44rpx}
.pf-avatar-img{width:100%;height:100%;border-radius:50%}
.pf-info{flex:1;display:flex;flex-direction:column;gap:4rpx}
.pf-nick{font-size:32rpx;font-weight:700;color:#3f2c15}
.pf-id{font-size:22rpx;color:rgba(63,44,21,0.4)}
.pf-birth{font-size:24rpx;color:#3f2c15}
.pf-birth-hint{font-size:22rpx;color:rgba(63,44,21,0.3)}

/* 快捷4宫格 */
.quick-grid{display:grid;grid-template-columns:1fr 1fr;gap:12rpx;margin-bottom:16rpx}
.quick-card{--qc:#FF9A56;background:#ffecda;padding:16rpx 10rpx;text-align:center;
  box-shadow:3rpx 0 var(--qc),-3rpx 0 var(--qc),0 -3rpx var(--qc),0 3rpx var(--qc),
    6rpx 0 var(--qc),-6rpx 0 var(--qc),0 -6rpx var(--qc),0 6rpx var(--qc),
    0 0 0 3rpx var(--qc),0 0 0 6rpx #fff,
    6rpx 0 0 3rpx #fff,-6rpx 0 0 3rpx #fff,
    0 -6rpx 0 3rpx #fff,0 6rpx 0 3rpx #fff}
.quick-card:active{transform:scale(.96)}
.qc-icon{font-size:32rpx;display:block}
.qc-count{font-size:28rpx;font-weight:800;color:var(--qc);display:block}
.qc-title{font-size:22rpx;font-weight:700;color:#3f2c15;display:block}
.qc-desc{font-size:18rpx;color:rgba(63,44,21,0.35);display:block;margin-top:4rpx}

/* 📔 食光日记入口 */
.diary-entry{display:flex;align-items:center;gap:16rpx;padding:20rpx;margin-bottom:12rpx;
  background:#ffecda;
  box-shadow:3rpx 0 #FF9A56,-3rpx 0 #FF9A56,0 -3rpx #FF9A56,0 3rpx #FF9A56,
    6rpx 0 #FF9A56,-6rpx 0 #FF9A56,0 -6rpx #FF9A56,0 6rpx #FF9A56,
    0 0 0 3rpx #FF9A56,0 0 0 6rpx #fff,
    6rpx 0 0 3rpx #fff,-6rpx 0 0 3rpx #fff,
    0 -6rpx 0 3rpx #fff,0 6rpx 0 3rpx #fff}
.diary-entry:active{transform:translate(2rpx,2rpx)}
.de-icon{font-size:44rpx}
.de-info{flex:1}
.de-title{font-size:28rpx;font-weight:700;color:#3f2c15;display:block}
.de-desc{font-size:20rpx;color:rgba(63,44,21,0.35);display:block;margin-top:2rpx}
.de-arrow{font-size:36rpx;color:#FF9A56}

/* 🍳 烹饪时光 */
.cooking-section{background:#ffecda;margin-bottom:16rpx;overflow:hidden;
  box-shadow:3rpx 0 #FF9A56,-3rpx 0 #FF9A56,0 -3rpx #FF9A56,0 3rpx #FF9A56,
    6rpx 0 #FF9A56,-6rpx 0 #FF9A56,0 -6rpx #FF9A56,0 6rpx #FF9A56,
    0 0 0 3rpx #FF9A56,0 0 0 6rpx #fff,
    6rpx 0 0 3rpx #fff,-6rpx 0 0 3rpx #fff,
    0 -6rpx 0 3rpx #fff,0 6rpx 0 3rpx #fff}
.cooking-hd{display:flex;align-items:center;gap:12rpx;padding:20rpx 24rpx;
  background:linear-gradient(135deg,#ffecda,#ffe0c0)}
.cooking-title{font-size:30rpx;font-weight:800;color:#3f2c15;flex:1}
.cooking-count{font-size:24rpx;color:rgba(63,44,21,0.45)}
.cooking-arrow{font-size:22rpx;color:#FF9A56}
.cooking-bd{max-height:0;overflow:hidden;transition:max-height .3s}
.cooking-bd.show{max-height:600rpx;padding:0 24rpx 20rpx}
.cooking-empty{font-size:24rpx;color:rgba(63,44,21,0.35);padding:20rpx 0;text-align:center}
.cooking-item{display:flex;justify-content:space-between;padding:12rpx 0;border-bottom:1rpx solid rgba(63,44,21,0.08)}
.ci-name{font-size:26rpx;color:#3f2c15;font-weight:600}
.ci-date{font-size:22rpx;color:rgba(63,44,21,0.4)}
.cooking-actions{display:flex;gap:16rpx;margin-top:16rpx}
.cooking-btn{flex:1;text-align:center;padding:14rpx;border:none;font-size:24rpx;font-weight:600;
  background:#FF9A56;color:#fff;box-shadow:4rpx 4rpx 0 #e07d3a}
.cooking-btn:active{transform:translate(2rpx,2rpx);box-shadow:2rpx 2rpx 0 #e07d3a}
.cooking-btn.sync{background:#79bcff;box-shadow:4rpx 4rpx 0 #5a90d4}

/* 设置区 */
.settings-section{background:#ffecda;margin-bottom:16rpx;overflow:hidden;
  box-shadow:3rpx 0 #FF9A56,-3rpx 0 #FF9A56,0 -3rpx #FF9A56,0 3rpx #FF9A56,
    6rpx 0 #FF9A56,-6rpx 0 #FF9A56,0 -6rpx #FF9A56,0 6rpx #FF9A56,
    0 0 0 3rpx #FF9A56,0 0 0 6rpx #fff,
    6rpx 0 0 3rpx #fff,-6rpx 0 0 3rpx #fff,
    0 -6rpx 0 3rpx #fff,0 6rpx 0 3rpx #fff}
.set-item{display:flex;justify-content:space-between;align-items:center;padding:20rpx 24rpx;
  font-size:26rpx;color:#3f2c15;border-bottom:1rpx solid rgba(0,0,0,0.04)}
.set-item:active{background:rgba(0,0,0,0.03)}
.set-item.warn{color:#e74c3c}
.set-arrow{font-size:30rpx;color:rgba(0,0,0,0.2)}

/* 编辑资料弹窗 */
.modal-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.4);z-index:2000;justify-content:center;align-items:center}
.modal-overlay.show{display:flex}
.modal-sheet{width:85%;max-width:600rpx;background:#ffecda;overflow:hidden;
  box-shadow:3rpx 0 #FF9A56,-3rpx 0 #FF9A56,0 -3rpx #FF9A56,0 3rpx #FF9A56,
    6rpx 0 #FF9A56,-6rpx 0 #FF9A56,0 -6rpx #FF9A56,0 6rpx #FF9A56,
    0 0 0 3rpx #FF9A56,0 0 0 6rpx #fff,
    6rpx 0 0 3rpx #fff,-6rpx 0 0 3rpx #fff,
    0 -6rpx 0 3rpx #fff,0 6rpx 0 3rpx #fff}
.modal-hd{display:flex;justify-content:space-between;align-items:center;padding:20rpx 24rpx;background:#FF9A56;color:#fff;font-weight:700;font-size:28rpx}
.modal-close{font-size:34rpx;padding:4rpx}
.modal-body{padding:24rpx}
.form-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:20rpx}
.form-label{font-size:26rpx;color:#3f2c15;font-weight:600}
.form-input{border:2rpx solid #FF9A56;padding:10rpx 16rpx;border-radius:6rpx;font-size:26rpx;width:60%;text-align:right}
.form-picker{border:2rpx solid #FF9A56;padding:10rpx 16rpx;border-radius:6rpx;font-size:26rpx;color:#3f2c15}
.btn-save{width:100%;padding:16rpx;background:#FF9A56;color:#fff;font-size:28rpx;font-weight:700;border:none;
  box-shadow:4rpx 4rpx 0 #e07d3a;margin-top:10rpx}
.btn-save:active{transform:translate(2rpx,2rpx);box-shadow:2rpx 2rpx 0 #e07d3a}

/* 小鸟设置 */
.bird-section{background:#ffecda;margin-bottom:16rpx;padding:20rpx;position:relative;z-index:5;
  box-shadow:3rpx 0 #FF9A56,-3rpx 0 #FF9A56,0 -3rpx #FF9A56,0 3rpx #FF9A56,
    6rpx 0 #FF9A56,-6rpx 0 #FF9A56,0 -6rpx #FF9A56,0 6rpx #FF9A56,
    0 0 0 3rpx #FF9A56,0 0 0 6rpx #fff,
    6rpx 0 0 3rpx #fff,-6rpx 0 0 3rpx #fff,
    0 -6rpx 0 3rpx #fff,0 6rpx 0 3rpx #fff}
.bird-hd{margin-bottom:12rpx}
.bird-title{font-size:28rpx;font-weight:700;color:#3f2c15}
.bird-modes{display:flex;gap:12rpx;margin-bottom:12rpx}
.bird-mode{flex:1;text-align:center;padding:14rpx;border-radius:8rpx;font-size:24rpx;
  border:2rpx solid rgba(0,0,0,0.08);color:rgba(63,44,21,0.5)}
.bird-mode:active{background:rgba(255,154,86,0.08);border-color:#FF9A56}
.bird-mode.active{background:rgba(255,154,86,0.12);color:#3f2c15;font-weight:700;border-color:#FF9A56}
.bird-pages{display:flex;flex-wrap:wrap;gap:10rpx;position:relative;z-index:1}
.bird-page{display:flex;align-items:center;gap:8rpx;padding:12rpx 18rpx;border-radius:6rpx;
  font-size:24rpx;border:2rpx solid rgba(0,0,0,0.06);color:rgba(63,44,21,0.4)}
.bird-page-hover{background:rgba(255,154,86,0.1);border-color:#FF9A56 !important}
.bird-page.on{border-color:#FF9A56;background:rgba(255,154,86,0.08);color:#3f2c15;font-weight:600}
.bp-check{color:#FF9A56;font-weight:700;font-size:22rpx}
