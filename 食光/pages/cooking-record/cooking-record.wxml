<!-- 🍳 烹饪食光 - 便签日记 -->
<navigation-bar title="烹饪食光" color="#1a1a2e" background="rgba(255,255,255,0.85)" back="{{true}}"></navigation-bar>

<scroll-view class="page" scroll-y enhanced show-scrollbar="{{false}}">

  <!-- 顶部操作 -->
  <view class="top-bar">
    <view class="add-btn" bindtap="openNew"><text>＋ 记一笔</text></view>
    <view class="sync-btn" bindtap="syncToCloud"><text>☁️ 同步</text></view>
  </view>

  <!-- 交错瀑布流 -->
  <view class="masonry" wx:if="{{records.length > 0}}">
    <view class="masonry-col">
      <block wx:for="{{records}}" wx:key="id" wx:if="{{index % 2 === 0}}">
        <view class="sticky" data-id="{{item.id}}" bindtap="editRecord" data-id="{{item.id}}">
          <image wx:if="{{item.img}}" src="{{item.img}}" mode="aspectFill" class="sticky-img" data-src="{{item.img}}" catchtap="previewImg"></image>
          <view class="sticky-bd">
            <text class="sticky-title">{{item.recipeName}}</text>
            <text class="sticky-date">📅 {{item.cookedAt}}</text>
            <text class="sticky-notes" wx:if="{{item.notes}}">{{item.notes}}</text>
          </view>
          <view class="sticky-actions">
            <text data-id="{{item.id}}" catchtap="deleteRecord">🗑️</text>
            <text>☁️</text>
          </view>
        </view>
      </block>
    </view>
    <view class="masonry-col">
      <block wx:for="{{records}}" wx:key="id" wx:if="{{index % 2 === 1}}">
        <view class="sticky {{item.color || 'n2'}}" data-id="{{item.id}}" bindtap="editRecord" data-id="{{item.id}}">
          <image wx:if="{{item.img}}" src="{{item.img}}" mode="aspectFill" class="sticky-img" data-src="{{item.img}}" catchtap="previewImg"></image>
          <view class="sticky-bd">
            <text class="sticky-title">{{item.recipeName}}</text>
            <text class="sticky-date">📅 {{item.cookedAt}}</text>
            <text class="sticky-notes" wx:if="{{item.notes}}">{{item.notes}}</text>
          </view>
          <view class="sticky-actions">
            <text data-id="{{item.id}}" catchtap="deleteRecord">🗑️</text>
            <text>☁️</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="empty" wx:if="{{records.length === 0}}">
    <text style="font-size:64rpx">🍳</text>
    <text>还没有烹饪记录</text>
    <text style="font-size:22rpx;color:rgba(63,44,21,0.25)">点击上方 ＋ 记下你的美食时光</text>
  </view>

  <view style="height:100rpx"></view>
</scroll-view>

<!-- 编辑弹窗 -->
<view class="modal-overlay {{showForm ? 'show' : ''}}" bindtap="closeForm">
  <view class="modal-sheet" catchtap="preventClose">
    <view class="modal-hd"><text>{{editId ? '编辑便签' : '记一笔'}}</text><view class="modal-x" bindtap="closeForm">✕</view></view>
    <view class="modal-body">
      <view class="fg"><text class="fl">菜谱</text>
        <scroll-view scroll-y style="max-height:160rpx" wx:if="{{diyRecipes.length > 0}}">
          <view class="pick {{form.recipeId === item.id ? 'on' : ''}}" wx:for="{{diyRecipes}}" wx:key="id" wx:for-index="ri" data-index="{{ri}}" bindtap="pickRecipe">
            <text>{{item.coverEmoji || '🍽️'}} {{item.name}}</text>
          </view>
        </scroll-view>
        <input wx:else class="fi" placeholder="菜名" value="{{form.recipeName}}" bindinput="onNameInput"/>
      </view>
      <view class="fg"><text class="fl">日期</text>
        <picker mode="date" value="{{form.cookedAt}}" bindchange="onDateChange"><view class="fp">{{form.cookedAt || '选择日期'}}</view></picker>
      </view>
      <view class="fg"><text class="fl">语音</text>
        <view wx:if="{{form.voice}}" class="voice-done" bindtap="playVoice"><text>🔊 点击播放</text></view>
        <view wx:else class="voice-btn {{recording ? 'ing' : ''}}" bindtap="toggleVoice">
          <text>{{recording ? '🔴 录制中...' : '🎤 录音'}}</text>
        </view>
      </view>
      <view class="fg"><text class="fl">照片</text>
        <view class="img-pick" bindtap="pickImg">
          <image wx:if="{{form.img}}" src="{{form.img}}" mode="aspectFill" class="img-inner"></image>
          <text wx:else>📸 拍照</text>
        </view>
      </view>
      <view class="fg"><text class="fl">备注</text>
        <textarea class="fi ta" placeholder="味道如何？" value="{{form.notes}}" bindinput="onNotesInput"/>
      </view>
      <button class="btn-save" bindtap="saveRecord">📌 钉上便签</button>
    </view>
  </view>
</view>
