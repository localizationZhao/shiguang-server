/* 做菜记录 - 像素便签风 */
.page{height:100vh;padding:0 16rpx}
.card{background:var(--bg);padding:20rpx;margin-bottom:12rpx;
  box-shadow:var(--border) 0 var(--hl),var(--neg-border) 0 var(--hl),0 calc(var(--neg-border)) var(--hl),0 var(--border) var(--hl),calc(var(--border)*2) 0 var(--hl),calc(var(--neg-border)*2) 0 var(--hl),0 calc(var(--neg-border)*2) var(--hl),0 calc(var(--border)*2) var(--hl),0 0 0 var(--border) var(--hl),0 0 0 calc(var(--border)*2) #fff,calc(var(--border)*2) 0 0 var(--border) #fff,calc(var(--neg-border)*2) 0 0 var(--border) #fff,0 calc(var(--neg-border)*2) 0 var(--border) #fff,0 calc(var(--border)*2) 0 var(--border) #fff)}
.record-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10rpx}
.record-name{font-size:26rpx;font-weight:700;color:#3f2c15;display:block}.record-date{font-size:20rpx;color:rgba(63,44,21,0.4);display:block}
.record-actions{font-size:28rpx;display:flex}.record-img{width:100%;aspect-ratio:4/3;object-fit:cover;border:2rpx solid var(--hl);margin-bottom:8rpx}.record-notes{font-size:22rpx;color:rgba(63,44,21,0.5)}
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80rpx 40rpx;gap:12rpx;color:rgba(63,44,21,0.4)}
.modal-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:1000;justify-content:center;align-items:center;padding:0 40rpx}.modal-overlay.show{display:flex}
.modal-sheet{background:var(--bg);width:100%;max-width:600rpx;max-height:70vh;overflow-y:auto;
  box-shadow:var(--border) 0 var(--hl),var(--neg-border) 0 var(--hl),0 calc(var(--neg-border)) var(--hl),0 var(--border) var(--hl),calc(var(--border)*2) 0 var(--hl),calc(var(--neg-border)*2) 0 var(--hl),0 calc(var(--neg-border)*2) var(--hl),0 calc(var(--border)*2) var(--hl),0 0 0 var(--border) var(--hl),0 0 0 calc(var(--border)*2) #fff,calc(var(--border)*2) 0 0 var(--border) #fff,calc(var(--neg-border)*2) 0 0 var(--border) #fff,0 calc(var(--neg-border)*2) 0 var(--border) #fff,0 calc(var(--border)*2) 0 var(--border) #fff)}
.modal-header{padding:14rpx 30rpx;display:flex;align-items:center;justify-content:space-between;background:var(--hl);color:var(--bg)}.modal-title{font-size:26rpx;font-weight:700}.modal-close{font-size:28rpx;padding:4rpx 10rpx;color:var(--bg)}
.modal-body{padding:24rpx 28rpx 40rpx}
.form-group{margin-bottom:20rpx}.form-label{font-size:24rpx;font-weight:600;color:#3f2c15;display:block;margin-bottom:8rpx}
.form-input{width:100%;height:72rpx;line-height:1.5;padding:0 18rpx;border:3rpx solid var(--hl);font-size:26rpx;background:rgba(255,255,255,0.5);color:#3f2c15;box-sizing:border-box}
.btn-primary{width:100%;padding:14rpx;background:var(--hl);color:var(--bg);border:none;font-size:26rpx;font-weight:700;text-align:center}
.recipe-pick-item{display:flex;justify-content:space-between;padding:14rpx 16rpx;border-bottom:2rpx solid rgba(0,0,0,0.05);font-size:24rpx}.recipe-pick-item.selected{background:rgba(255,163,203,0.06)}
.record-img-pick{width:100%;aspect-ratio:4/3;border:3rpx dashed var(--hl);display:flex;align-items:center;justify-content:center;overflow:hidden}.record-img-pick .record-img-inner{width:100%;height:100%}
@keyframes fadeUp{from{opacity:0;transform:translateY(60rpx)}to{opacity:1;transform:translateY(0)}}
