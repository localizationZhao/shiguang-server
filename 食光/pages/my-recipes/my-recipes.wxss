.page{height:100vh;padding:12rpx 16rpx;box-sizing:border-box}
.empty{text-align:center;padding:60rpx;font-size:26rpx;color:rgba(63,44,21,0.35)}
.list-card{display:flex;align-items:center;gap:16rpx;padding:20rpx;margin-bottom:10rpx;background:#ffecda;border-radius:8rpx;
  box-shadow:3rpx 3rpx 0 rgba(0,0,0,0.05),0 0 0 2rpx #fff,0 0 0 4rpx #ffa3cb}
.lc-emoji{font-size:40rpx}
.lc-info{flex:1}
.lc-name{font-size:28rpx;font-weight:700;color:#3f2c15;display:block}
.lc-meta{font-size:22rpx;color:rgba(63,44,21,0.4);display:block;margin-top:4rpx}
.lc-arrow{font-size:32rpx;color:rgba(63,44,21,0.2)}
