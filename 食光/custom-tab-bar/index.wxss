/* ===== 像素风TabBar ===== */
.tab-bar {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 999;
  height: 130rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 6rpx solid #e8ecf2;
  display: flex; justify-content: space-around; align-items: center;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.05);
}

.tab-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 4rpx; position: relative;
  padding-top: 8rpx;
  border-radius: 20rpx;
  margin: 4rpx 8rpx;
  transition: transform .15s ease, background .15s ease;
}
.tab-item:active {
  transform: scale(.92) translateY(4rpx);
  background: rgba(255,73,151,0.15) !important;
}

/* 点击闪光动画 */
.tab-item.tap-flash {
  animation: tabFlash .25s ease;
}
@keyframes tabFlash {
  0%   { transform: scale(.88) translateY(4rpx); }
  100% { transform: scale(1) translateY(0); }
}

/* 像素图标 */
.tab-icon-img {
  width: 48rpx; height: 48rpx;
  image-rendering: pixelated;  /* 像素风不模糊 */
  transition: all .2s;
}

/* 文字 */
.tab-text {
  font-size: 24rpx; font-weight: 600;
  color: #99a2b5;
  letter-spacing: 2rpx;
  transition: all .2s;
}

/* ===== 未选中态：清晰但低调 ===== */
.tab-item .tab-icon-img {
  opacity: .7;
}
.tab-item .tab-text {
  color: #8892a5;
  font-weight: 500;
}

/* ===== 选中态——图标放大 + 文字橘色小底块 ===== */
.tab-item.active {
  background: transparent;
  box-shadow: none;
  margin: 4rpx 8rpx;
}
.tab-item.active .tab-icon-img {
  width: 56rpx; height: 56rpx;
  transform: translateY(-6rpx);
  opacity: 1;
}
.tab-item.active .tab-text {
  font-size: 24rpx; font-weight: 700;
  color: #FF9A56;
  background: rgba(255,154,86,0.15);
  border-radius: 10rpx;
  padding: 2rpx 16rpx;
  text-shadow: none;
}

/* 选中指示线——橘色短线 */
.tab-line {
  width: 28rpx; height: 5rpx;
  border-radius: 3rpx;
  background: #FF9A56;
  margin-top: 2rpx;
}
