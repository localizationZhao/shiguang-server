/* ===== 像素风TabBar ===== */
.tab-bar {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 999;
  height: 130rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 6rpx solid #e8ecf2;
  display: flex; justify-content: space-around; align-items: center;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.05);
}

.tab-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 4rpx; position: relative;
  padding-top: 8rpx;
  border-radius: 20rpx;
  margin: 4rpx 8rpx;
  transition: all .15s ease;
}
.tab-item:active {
  transform: scale(.92) translateY(4rpx);
  background: rgba(255,73,151,0.15) !important;
}

/* 点击闪光动画 */
.tab-item.tap-flash {
  animation: tabFlash .25s ease;
}
@keyframes tabFlash {
  0%   { background: var(--tab-color); transform: scale(.88) translateY(6rpx); }
  50%  { background: var(--tab-color); opacity: .35; transform: scale(.95) translateY(2rpx); }
  100% { background: transparent; opacity: 1; transform: scale(1) translateY(0); }
}

/* 像素图标 */
.tab-icon-img {
  width: 48rpx; height: 48rpx;
  image-rendering: pixelated;  /* 像素风不模糊 */
  transition: all .2s;
}

/* 文字 */
.tab-text {
  font-size: 24rpx; font-weight: 600;
  color: #99a2b5;
  letter-spacing: 2rpx;
  transition: all .2s;
}

/* ===== 未选中态：淡色 ===== */
.tab-item .tab-icon-img {
  opacity: .5;
}
.tab-item .tab-text {
  color: #a8b0c0;
  font-weight: 500;
}

/* ===== 选中态——纯色加深填充 ===== */
.tab-item.active {
  background: var(--tab-color, #ff4997);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15), 0 2rpx 0 rgba(0,0,0,0.1);
  margin: 2rpx 6rpx;
}
.tab-item.active .tab-icon-img {
  width: 50rpx; height: 50rpx;
  transform: translateY(-4rpx);
  opacity: 1;
  background: rgba(255,255,255,0.25);
  border-radius: 50%;
  padding: 6rpx;
}
.tab-item.active .tab-text {
  font-size: 26rpx; font-weight: 800;
  color: #fff;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.15);
}

/* 选中指示线——白色短线 */
.tab-line {
  width: 36rpx; height: 6rpx;
  border-radius: 3rpx;
  background: rgba(255,255,255,0.8);
  margin-top: 2rpx;
}
