/* pages/test/test.wxss */

/* 页面容器 */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 模块标题 */
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #07C160;
  padding: 20rpx 0;
  border-bottom: 4rpx solid #07C160;
  margin-bottom: 20rpx;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: #ddd;
  margin: 40rpx 0;
}

/* 数据项容器 */
.data-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 数据类型标签 */
.type-label {
  font-size: 24rpx;
  color: #fff;
  background-color: #07C160;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  display: inline-block;
}

.type-label.blue {
  background-color: #1890ff;
}

.type-label.orange {
  background-color: #fa8c16;
}

.type-label.red {
  background-color: #f5222d;
}

.type-label.purple {
  background-color: #722ed1;
}

/* 数据值 */
.data-value {
  font-size: 28rpx;
  color: #333;
  margin-top: 10rpx;
  word-break: break-all;
}

/* 运算表达式 */
.expression {
  font-size: 26rpx;
  color: #666;
  background-color: #f9f9f9;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
  font-family: 'Courier New', monospace;
}

/* 条件渲染结果 */
.cond-result {
  font-size: 28rpx;
  padding: 12rpx;
  border-radius: 8rpx;
  margin-top: 10rpx;
}

.cond-result.success {
  background-color: #e6f7e6;
  color: #52c41a;
}

.cond-result.warning {
  background-color: #fff7e6;
  color: #fa8c16;
}

.cond-result.info {
  background-color: #e6f4ff;
  color: #1890ff;
}

/* 列表项 */
.list-item {
  padding: 8rpx 0;
  border-bottom: 1rpx solid #eee;
}

.list-item:last-child {
  border-bottom: none;
}

/* 复杂数据展示 */
.complex-item {
  padding: 10rpx;
  background-color: #fafafa;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}


/* ==================== 练习二补充功能样式 ==================== */

/* 3.1 乘法表倒序样式 */
.multiply-row {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.multiply-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.multiply-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #07C160;
  margin-right: 8rpx;
}

.multiply-label {
  font-size: 24rpx;
  color: #999;
}

.multiply-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.multiply-item {
  background-color: #f0f9f0;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #333;
  font-family: 'Courier New', monospace;
}

/* 3.2 随身物品列表样式 */
.items-list {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.item-card {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.item-card:last-child {
  border-bottom: none;
}

.item-index {
  width: 100rpx;
  font-size: 24rpx;
  color: #999;
}

.item-content {
  display: flex;
  align-items: center;
  flex: 1;
}

.item-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.item-name {
  font-size: 30rpx;
  color: #333;
}

/* 3.3 设备对象渲染样式 */
.device-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.device-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #eee;
}

.device-brand {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.device-model {
  font-size: 26rpx;
  color: #666;
}

.device-specs {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.spec-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #eee;
}

.spec-row:last-child {
  border-bottom: none;
}

.spec-label {
  font-size: 26rpx;
  color: #999;
}

.spec-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 3.4 设备类型判定样式 */
.device-type-info {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.device-type-tag {
  margin-left: 12rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

.device-type-tag.apple {
  background-color: #333;
}

.device-type-tag.android {
  background-color: #3ddc84;
}

.device-type-tag.windows {
  background-color: #0078d4;
}

.device-image-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.device-image-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.device-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.unknown-device {
  width: 100%;
  height: 200rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}
