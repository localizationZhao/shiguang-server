/* pages/event/event.wxss */

/* 页面容器 */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 模块标题 */
.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1890ff;
  padding: 20rpx 0;
  border-bottom: 4rpx solid #1890ff;
  margin-bottom: 20rpx;
}

/* 子标题 */
.sub-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: #ddd;
  margin: 40rpx 0;
}

/* 数据项容器 */
.data-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 按钮样式 */
.btn {
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  margin: 8rpx;
  transition: all 0.2s ease;
}

.btn:active {
  transform: scale(0.96);
}

.btn-success {
  background-color: #52c41a;
}

.btn-danger {
  background-color: #f5222d;
}

.btn-warning {
  background-color: #fa8c16;
}

/* 数值展示 */
.counter-display {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
  text-align: center;
  padding: 20rpx;
}

/* 状态文本 */
.status-text {
  font-size: 32rpx;
  color: #333;
  padding: 16rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  text-align: center;
}

/* 列表项 */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item.selected {
  background-color: #e6f7ff;
}

/* 参数传参按钮组 */
.param-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 参数结果 */
.param-result {
  font-size: 26rpx;
  color: #666;
  background-color: #f9f9f9;
  padding: 12rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

/* 冒泡事件演示容器 */
.bubble-demo {
  padding: 20rpx;
}

.outer-box {
  background-color: #ffccc7;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.middle-box {
  background-color: #d9f7be;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.inner-box {
  background-color: #bae7ff;
  padding: 30rpx;
  border-radius: 12rpx;
  text-align: center;
}

.log-text {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 提示信息 */
.tip {
  font-size: 26rpx;
  color: #fa8c16;
  background-color: #fff7e6;
  padding: 12rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

/* 用户信息卡片 */
.user-card {
  background-color: #f9f9f9;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.user-card text {
  display: block;
  margin-bottom: 8rpx;
}


/* ==================== 模块6：乘法表倒序样式 ==================== */
.multiply-row {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.multiply-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.multiply-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #1890ff;
  margin-right: 8rpx;
}

.multiply-label {
  font-size: 24rpx;
  color: #999;
}

.multiply-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.multiply-item {
  background-color: #e6f4ff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #333;
  font-family: 'Courier New', monospace;
}


/* ==================== 模块7：随身物品列表样式 ==================== */
.items-list {
  margin-top: 12rpx;
}

.item-card {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.item-card:last-child {
  border-bottom: none;
}

.item-index {
  width: 100rpx;
  font-size: 24rpx;
  color: #999;
}

.item-content {
  display: flex;
  align-items: center;
  flex: 1;
}

.item-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.item-name {
  font-size: 30rpx;
  color: #333;
}


/* ==================== 模块8：设备对象渲染样式 ==================== */
.device-card {
  margin-top: 12rpx;
}

.device-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #eee;
}

.device-brand {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.device-model {
  font-size: 26rpx;
  color: #666;
}

.device-specs {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.spec-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #eee;
}

.spec-row:last-child {
  border-bottom: none;
}

.spec-label {
  font-size: 26rpx;
  color: #999;
}

.spec-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}


/* ==================== 模块9：条件渲染图片样式 ==================== */
.device-type-info {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.device-type-tag {
  margin-left: 12rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

.device-type-tag.apple {
  background-color: #333;
}

.device-type-tag.android {
  background-color: #3ddc84;
}

.device-type-tag.windows {
  background-color: #0078d4;
}

.device-image-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.device-image-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.device-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.unknown-device {
  width: 100%;
  height: 200rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}
