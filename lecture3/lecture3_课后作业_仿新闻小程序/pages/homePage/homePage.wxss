/* pages/homePage/homePage.wxss */

/* 加载提示 */
.loading-view {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 整体容器 */
.mainViewClass {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #f5f5f5;
}

/* 顶部菜单栏 */
.topTabBarClass {
  background-color: #ffa589;
  display: flex;
  flex-direction: row;
  width: 100%;
  height: 80rpx;
  flex-shrink: 0;
}

/* 每个菜单项 */
.topTypeListClass {
  display: inline-block;
  margin-top: 12rpx;
  margin-left: 10rpx;
  font-size: 30rpx;
  width: 100rpx;
  height: 100%;
  text-align: center;
  color: #333;
  line-height: 80rpx;
  transition: all 0.3s;
}

/* 选中样式 */
.curPage {
  color: #fff;
  font-size: 35rpx;
  font-weight: bold;
}

/* 右侧按钮容器 */
.rightview {
  background-color: transparent;
  height: 100%;
  width: 10%;
  position: relative;
}

.addImage {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  margin: auto;
}

/* 新闻 cell */
.cellClass {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx;
  background: white;
  border-bottom: 1rpx solid #ddd;
  margin-bottom: 10rpx;
}

.cellClass text {
  font-size: 32rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
}

/* 图片容器（flex 三列） */
.imageClass {
  width: 100%;
  display: flex;
  flex-direction: row;
  height: 150rpx;
  justify-content: space-around;
  margin: 10rpx 0;
}

.imageshow {
  width: 230rpx;
  height: 150rpx;
  border-radius: 8rpx;
}

/* 底部评论时间栏 */
.cellbottomClass {
  width: 100%;
  height: 44rpx;
  color: #999;
  font-size: 24rpx;
  margin-top: 10rpx;
  display: flex;
  align-items: center;
}

.cellbottomClass text {
  margin-right: 20rpx;
}

/* 分类项容器（包含标签和删除按钮） */
.category-wrapper {
  display: inline-flex;
  align-items: center;
  position: relative;
}

/* 删除按钮 */
.remove-btn {
  position: absolute;
  right: -8rpx;
  top: -12rpx;
  width: 32rpx;
  height: 32rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  font-size: 22rpx;
  text-align: center;
  line-height: 32rpx;
  z-index: 10;
}

/* 频道选择弹窗 */
.channel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.channel-picker {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
}

.channel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #eee;
}

.channel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  font-size: 36rpx;
  color: #999;
  text-align: center;
  line-height: 48rpx;
}

.channel-list {
  flex: 1;
  padding: 16rpx 32rpx;
}

.channel-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  color: #333;
}

.channel-item:last-child {
  border-bottom: none;
}

.add-icon {
  font-size: 32rpx;
  color: #1890ff;
  font-weight: bold;
}

/* 空状态提示 */
.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
