/* pages/userCenter/userCenter.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  background-color: #ff5400;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.username {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.menu-list {
  margin-top: 20rpx;
}

.menu-item {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 2rpx;
  font-size: 28rpx;
  color: #333;
}
