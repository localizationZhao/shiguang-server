/* pages/container/container.wxss */

/* 页面容器 */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 模块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #9c27b0;
  padding: 20rpx 0;
  border-bottom: 4rpx solid #9c27b0;
  margin-bottom: 20rpx;
  margin-top: 20rpx;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

/* ==================== view 容器样式 ==================== */
.course-list {
  display: flex;
  flex-direction: column;
}

.course-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.course-item:last-child {
  border-bottom: none;
}

.course-day {
  width: 80rpx;
  font-size: 26rpx;
  color: #9c27b0;
  font-weight: bold;
}

.course-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
}

.course-name {
  font-size: 28rpx;
  color: #333;
}

.course-time {
  font-size: 24rpx;
  color: #999;
}

/* view hover 点击态演示样式 */
.hover-demo-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hover-item {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #fff;
  transition: background-color 0.15s ease;
}

.hover-normal {
  background-color: #4a90d9;
}

.hover-delay {
  background-color: #52c41a;
}

.hover-none {
  background-color: #fa8c16;
}

.hover-active {
  background-color: #9c27b0 !important;
  transform: scale(0.96);
}

/* view flex 布局演示样式 */
.flex-section {
  margin-bottom: 24rpx;
}

.flex-section:last-child {
  margin-bottom: 0;
}

.flex-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.flex-container {
  display: flex;
  gap: 12rpx;
}

.flex-row {
  flex-direction: row;
}

.flex-column {
  flex-direction: column;
}

.flex-block {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #fff;
}

.flex-block-v {
  height: 70rpx;
}

.flex-bg-blue {
  background-color: #4a90d9;
}

.flex-bg-green {
  background-color: #52c41a;
}

.flex-bg-orange {
  background-color: #fa8c16;
}

/* ==================== scroll-view 容器样式 ==================== */
/* 横向滚动 */
.scroll-view-h {
  width: 100%;
  white-space: nowrap;
}

/* 纵向滚动 */
.scroll-view-v {
  width: 100%;
}

.weather-list {
  display: flex;
  flex-direction: row;
}

.weather-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  margin-right: 16rpx;
  background-color: #f0f5ff;
  border-radius: 12rpx;
}

.weather-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.weather-city {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.weather-temp {
  font-size: 26rpx;
  color: #9c27b0;
  font-weight: bold;
}

/* 纵向滚动 */
.scroll-y {
  width: 100%;
}

.message-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.message-item:last-child {
  border-bottom: none;
}

.message-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.message-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.message-time {
  font-size: 24rpx;
  color: #999;
}

.message-content {
  font-size: 26rpx;
  color: #666;
}

/* scroll-into-view 滚动项样式 */
.scroll-item {
  height: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.demo-bg-1 {
  background-color: #e6f7ff;
  border-left: 4rpx solid #1890ff;
}

.demo-bg-2 {
  background-color: #f6ffed;
  border-left: 4rpx solid #52c41a;
}

.demo-bg-3 {
  background-color: #fff7e6;
  border-left: 4rpx solid #fa8c16;
}

.scroll-item-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

/* 按钮组 */
.btn-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.btn-small {
  flex: 1;
  min-width: 200rpx;
  font-size: 24rpx;
  padding: 12rpx 16rpx;
  margin-top: 0;
}

.btn-info {
  background-color: #1890ff;
}

.btn-info:active {
  transform: scale(0.96);
}

/* ==================== swiper 容器样式 ==================== */
.swiper-box {
  width: 100%;
  height: 300rpx;
}

.swiper-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.swiper-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.swiper-info {
  text-align: center;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

/* swiper 控制面板样式 */
.control-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.control-row:last-child {
  border-bottom: none;
}

.control-label {
  font-size: 28rpx;
  color: #333;
}

.slider-group {
  margin-top: 24rpx;
}

.slider-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.slider-label {
  font-size: 26rpx;
  color: #666;
}

.slider-value {
  font-size: 26rpx;
  color: #9c27b0;
  font-weight: bold;
}

/* ==================== movable-area / movable-view 样式 ==================== */
.movable-area {
  width: 100%;
  height: 300rpx;
  background-color: #f0f5ff;
  border-radius: 12rpx;
  position: relative;
  margin-bottom: 16rpx;
}

/* 小尺寸 movable-view */
.movable-view-small {
  width: 100rpx;
  height: 100rpx;
  background-color: #1890ff;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.movable-view-small text {
  color: #fff;
  font-size: 24rpx;
}

/* 大尺寸 movable-view（大于容器） */
.movable-view-large {
  width: 500rpx;
  height: 400rpx;
  background-color: #52c41a;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.movable-view-large text {
  color: #fff;
  font-size: 28rpx;
  text-align: center;
}

/* 按钮样式 */
.btn {
  background-color: #9c27b0;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  margin-top: 12rpx;
}

.btn:active {
  transform: scale(0.96);
}

/* ==================== match-media 样式 ==================== */
.match-result {
  padding: 20rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.match-result success {
  background-color: #e6f7e6;
  border-left: 4rpx solid #52c41a;
}

.match-result warning {
  background-color: #fff7e6;
  border-left: 4rpx solid #fa8c16;
}

.match-result info {
  background-color: #e6f4ff;
  border-left: 4rpx solid #1890ff;
}

/* ==================== page-container 样式 ==================== */
.popup-content {
  padding: 40rpx;
  background-color: #fff;
}

.popup-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.popup-desc {
  display: flex;
  flex-direction: column;
  margin-bottom: 30rpx;
}

.popup-desc text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.center-popup {
  border-radius: 24rpx;
  max-width: 80%;
  margin: 0 auto;
}

/* 次要按钮样式 */
.btn-secondary {
  background-color: #52c41a;
}

.btn-secondary:active {
  transform: scale(0.96);
}

/* 提示文本 */
.tip-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  line-height: 1.5;
}
