.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

.section {
  margin-top: 50px;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #ff5400;
}

.section-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.sub-section {
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.sub-section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.divider {
  width: 100%;
  height: 1rpx;
  background-color: #e0e0e0;
  margin: 30rpx 0;
}

.card {
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  margin-bottom: 15rpx;
  border: 1rpx solid #e8e8e8;
}

.card-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.btn {
  padding: 15rpx 30rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-right: 15rpx;
  margin-bottom: 15rpx;
}

.btn-primary {
  background-color: #ff5400;
  color: #fff;
}

.btn-default {
  background-color: #f5f5f5;
  color: #333;
  border: 1rpx solid #ddd;
}

.btn-group {
  display: flex;
  flex-wrap: wrap;
  padding: 10rpx 0;
}

.result-text {
  font-size: 26rpx;
  color: #666;
  margin-top: 15rpx;
  padding: 15rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
  padding: 15rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
}

/* ==================== 地图组件样式 ==================== */
.map {
  width: 100%;
  height: 300px;
  border-radius: 10rpx;
  margin-bottom: 15rpx;
}

/* ==================== 多选框样式 ==================== */
.checkbox-label {
  display: inline-block;
  width: 45%;
  margin-bottom: 15rpx;
  font-size: 28rpx;
  color: #333;
}

/* ==================== 单选框样式 ==================== */
.radio-label {
  display: inline-block;
  margin-right: 30rpx;
  font-size: 28rpx;
  color: #333;
}

.custom-radio-group {
  display: flex;
  flex-wrap: wrap;
}

.custom-radio-item {
  display: flex;
  align-items: center;
  padding: 15rpx 25rpx;
  margin-right: 20rpx;
  margin-bottom: 15rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.custom-radio-active {
  background-color: #fff0e8;
  border: 1rpx solid #ff5400;
}

/* ==================== 开关组件样式 ==================== */
.switch-row {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
  font-size: 28rpx;
  color: #333;
}

.switch-row text {
  flex: 1;
}

/* ==================== 画布组件样式 ==================== */
.canvas {
  width: 100%;
  height: 200px;
  background-color: #fff;
  border-radius: 10rpx;
}

/* ==================== 滑动选择器样式 ==================== */
.slider {
  margin: 20rpx 0;
}

/* ==================== 表单综合样式 ==================== */
input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-top: 10rpx;
}