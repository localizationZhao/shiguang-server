/**
 * scrollMedia.wxss - 横向滚动多媒体界面页面样式文件
 * 功能：定义页面布局、卡片样式、滚动容器样式
 * 知识点：Flex布局、scroll-view横向滚动、响应式设计
 */

/* 页面容器 */
.container {
  min-height: 100vh;
  padding: 20rpx;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

/* 模块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #07C160;
}

/* 模块描述 */
.section-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

/* 模块区域 */
.section {
  width: 100%;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

/* 小节区域 */
.section2 {
  width: 100%;
  padding: 20rpx;
  margin-bottom: 25rpx;
  background-color: #fff;
  border-radius: 10rpx;
  border: 1rpx solid #e8e8e8;
  box-sizing: border-box;
}

/* 小节标题 */
.section2-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

/* 分割线 */
.divider {
  width: 100%;
  height: 1rpx;
  background-color: #e0e0e0;
  margin: 30rpx 0;
}

/* ==================== 横向滚动容器样式 ==================== */

/* 横向滚动容器 */
.scroll-x-container {
  width: 100%;
  height: 420rpx;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

/* 卡片包装器 - 横向排列 */
.card-wrapper {
  display: inline-flex;
  padding: 10rpx;
}

/* 媒体卡片 */
.media-card {
  width: 300rpx;
  height: 380rpx;
  margin-right: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #e8e8e8;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  display: inline-block;
  vertical-align: top;
}

/* 卡片标题栏 */
.card-header {
  padding: 15rpx;
  background-color: #f8f8f8;
  border-bottom: 1rpx solid #e8e8e8;
}

/* 卡片标题 */
.card-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

/* 卡片内容区 */
.card-content {
  padding: 15rpx;
  height: calc(100% - 70rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ==================== 各类媒体内容样式 ==================== */

/* 文字内容 */
.text-content {
  font-size: 26rpx;
  color: #333;
  text-align: center;
  line-height: 1.6;
  word-break: break-all;
  white-space: normal;
}

/* 图片内容 */
.image-content {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

/* 音频内容 */
.audio-content {
  width: 100%;
}

/* 视频内容 */
.video-content {
  width: 100%;
  height: 100%;
}

/* 滚动提示 */
.scroll-tip {
  text-align: center;
  margin-top: 10rpx;
}

.scroll-tip text {
  font-size: 24rpx;
  color: #999;
}

/* ==================== 控制区样式 ==================== */

/* 输入框 */
.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  margin-bottom: 15rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 按钮基础样式 */
.btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 10rpx;
  margin: 10rpx;
}

/* 按钮组 */
.btn-group {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  padding: 10rpx 0;
}

/* 主按钮 */
.btn-primary {
  background-color: #07C160;
  color: #fff;
  border: none;
}

/* 成功按钮 */
.btn-success {
  background-color: #07C160;
  color: #fff;
  border: none;
}

/* 默认按钮 */
.btn-default {
  background-color: #f5f5f5;
  color: #333;
  border: 1rpx solid #ddd;
}

/* 警告按钮 */
.btn-warning {
  background-color: #ff976a;
  color: #fff;
  border: none;
}

/* 危险按钮 */
.btn-danger {
  background-color: #ff4d4f;
  color: #fff;
  border: none;
}