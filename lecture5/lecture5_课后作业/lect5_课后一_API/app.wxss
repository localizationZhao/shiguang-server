/**
 * app.wxss - 小程序全局样式文件
 * 定义全局通用样式，所有页面均可使用
 */

/* 页面容器基础样式 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  box-sizing: border-box;
  padding: 20rpx;
  background-color: #f5f5f5;
}

/* 模块标题样式 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #07C160;
}

/* 分割线样式 */
.divider {
  width: 100%;
  height: 1rpx;
  background-color: #e0e0e0;
  margin: 30rpx 0;
}

/* 模块区域样式 */
.section {
  width: 100%;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 按钮基础样式 */
.btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 10rpx;
  margin: 10rpx;
}

/* 按钮组样式 */
.btn-group {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  padding: 10rpx 0;
}