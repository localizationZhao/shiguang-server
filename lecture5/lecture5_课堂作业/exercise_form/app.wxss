.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

.section {
  margin-top: 50px;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #ff5400;
}

.section-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.sub-section {
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.sub-section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.divider {
  width: 100%;
  height: 1rpx;
  background-color: #e0e0e0;
  margin: 30rpx 0;
}

.btn {
  padding: 15rpx 30rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-right: 15rpx;
  margin-bottom: 15rpx;
}

.btn-primary {
  background-color: #ff5400;
  color: #fff;
}

.btn-default {
  background-color: #f5f5f5;
  color: #333;
  border: 1rpx solid #ddd;
}

.result-text {
  font-size: 26rpx;
  color: #666;
  margin-top: 15rpx;
  padding: 15rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
}

.card {
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  margin-bottom: 15rpx;
}