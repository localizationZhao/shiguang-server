<view class="container">
  
  <!-- ==================== 表单组件（二）模块 ==================== -->
  <view class="section">
    <view class="section-title">一、表单组件（二）</view>
    
    <!-- 1. 地图组件 map -->
    <view class="sub-section">
      <view class="sub-section-title">1. 地图组件 map</view>
      
      <!-- 第一组地图：完整配置 markers、polyline、controls -->
      <view class="card">
        <text class="card-title">1.1 完整地图配置（标记点、路线、控件）</text>
        <map 
          id="map1"
          class="map"
          longitude="113.324520"
          latitude="23.099994"
          scale="14"
          show-location="true"
          markers="{{markers}}"
          polyline="{{polyline}}"
          controls="{{controls}}"
          bindcontroltap="bindcontroltap"
          bindmarkertap="bindmarkertap"
          bindregionchange="bindregionchange"
          bindtap="bindtap">
        </map>
        <view class="result-text" wx:if="{{mapEventText}}">
          事件信息：{{mapEventText}}
        </view>
      </view>
      
      <!-- 第二组地图：circles 圆形区域 -->
      <view class="card">
        <text class="card-title">1.2 圆形区域演示（circles）</text>
        <map 
          id="map2"
          class="map"
          longitude="113.324520"
          latitude="23.099994"
          scale="14"
          show-location="true"
          circles="{{circles}}">
        </map>
      </view>
    </view>
    
    <!-- 分割线 -->
    <view class="divider"></view>
    
    <!-- 2. 多选框 checkbox -->
    <view class="sub-section">
      <view class="sub-section-title">2. 多选框 checkbox 与 checkbox-group</view>
      <checkbox-group bindchange="listenCheckboxChange">
        <label class="checkbox-label" wx:for="{{checkboxItems}}" wx:key="value">
          <checkbox value="{{item.value}}" checked="{{item.checked}}" color="#ff5400"/>
          {{item.name}}
        </label>
      </checkbox-group>
      <view class="result-text" wx:if="{{checkboxResult}}">
        选中结果：{{checkboxResult}}
      </view>
    </view>
    
    <!-- 分割线 -->
    <view class="divider"></view>
    
    <!-- 3. 单选框 radio -->
    <view class="sub-section">
      <view class="sub-section-title">3. 单选框 radio 与 radio-group</view>
      
      <!-- 基础单选演示 -->
      <view class="card">
        <text class="card-title">3.1 基础单选</text>
        <radio-group bindchange="radioChange">
          <label class="radio-label" wx:for="{{radioItems}}" wx:key="value">
            <radio value="{{item.value}}"/>{{item.name}}
          </label>
        </radio-group>
        <view class="result-text" wx:if="{{radioResult}}">
          选中：{{radioResult}}
        </view>
      </view>
      
      <!-- 自定义单选样式 -->
      <view class="card">
        <text class="card-title">3.2 自定义单选样式（icon组件）</text>
        <view class="custom-radio-group">
          <view 
            class="custom-radio-item {{selectedArea === item.id ? 'custom-radio-active' : ''}}"
            wx:for="{{customRadioItems}}" 
            wx:key="id"
            bindtap="selectAreaOk"
            data-areaId="{{item.id}}">
            <icon 
              type="{{selectedArea === item.id ? 'success' : 'circle'}}" 
              size="20" 
              color="{{selectedArea === item.id ? '#ff5400' : '#999'}}">
            </icon>
            <text>{{item.name}}</text>
          </view>
        </view>
        <view class="result-text" wx:if="{{customRadioResult}}">
          选中区域：{{customRadioResult}}
        </view>
      </view>
    </view>
    
    <!-- 分割线 -->
    <view class="divider"></view>
    
    <!-- 4. 开关组件 switch -->
    <view class="sub-section">
      <view class="sub-section-title">4. 开关组件 switch</view>
      
      <!-- 两种类型开关 -->
      <view class="card">
        <text class="card-title">4.1 开关类型演示</text>
        <view class="switch-row">
          <text>默认样式：</text>
          <switch checked="{{switch1}}" bindchange="switch1Change"/>
        </view>
        <view class="switch-row">
          <text>checkbox样式：</text>
          <switch type="checkbox" checked="{{switch2}}" bindchange="switch2Change"/>
        </view>
        <view class="result-text">
          switch1状态：{{switch1 ? '开' : '关'}} | switch2状态：{{switch2 ? '开' : '关'}}
        </view>
      </view>
      
      <!-- 按钮联动开关 -->
      <view class="card">
        <text class="card-title">4.2 按钮控制开关</text>
        <switch checked="{{switchSelect}}" />
        <button class="btn btn-primary" bindtap="switchOpen">打开</button>
        <button class="btn btn-default" bindtap="switchClose">关闭</button>
        <view class="result-text">
          开关状态：{{switchSelect ? '已打开' : '已关闭'}}
        </view>
      </view>
      
      <!-- slider+switch联动 -->
      <view class="card">
        <text class="card-title">4.3 slider+switch联动</text>
        <slider value="{{sliderValue}}" bindchange="sliderChange" />
        <switch checked="{{switchSelect}}" />
        <view class="result-text">
          slider值：{{sliderValue}} | switch状态：{{switchSelect ? '开' : '关'}}
        </view>
      </view>
    </view>
    
  </view>
  
  <!-- 大分割线 -->
  <view class="divider"></view>
  
  <!-- ==================== 表单组件（三）模块 ==================== -->
  <view class="section">
    <view class="section-title">二、表单组件（三）</view>
    
    <!-- 1. 画布组件 canvas -->
    <view class="sub-section">
      <view class="sub-section-title">1. 画布组件 canvas</view>
      <canvas canvas-id="myCanvas" class="canvas"></canvas>
      <view class="result-text">
        画布绘制内容：矩形、文字、直线
      </view>
    </view>
    
    <!-- 分割线 -->
    <view class="divider"></view>
    
    <!-- 2. 滑动选择器 slider -->
    <view class="sub-section">
      <view class="sub-section-title">2. 滑动选择器 slider</view>
      <view class="card">
        <text class="card-title">滑动选择器演示</text>
        <slider 
          min="0" 
          max="100" 
          value="{{sliderValue}}" 
          show-value="true"
          bindchange="sliderBindchange">
        </slider>
        <view class="result-text">
          最小值：0 | 最大值：100 | 当前值：{{sliderValue}}
        </view>
      </view>
    </view>
    
    <!-- 分割线 -->
    <view class="divider"></view>
    
    <!-- 3. 选择器 picker 与 picker-view -->
    <view class="sub-section">
      <view class="sub-section-title">3. 选择器 picker 与 picker-view</view>
      
      <!-- 普通选择器 -->
      <view class="card">
        <text class="card-title">3.1 普通选择器</text>
        <picker mode="selector" range="{{array}}" bindchange="pickerChange">
          <view class="picker-text">{{pickerIndex >= 0 ? array[pickerIndex] : '请选择'}}</view>
        </picker>
      </view>
      
      <!-- 时间选择器 -->
      <view class="card">
        <text class="card-title">3.2 时间选择器</text>
        <picker mode="time" bindchange="timePickerChange">
          <view class="picker-text">{{timeValue || '请选择时间'}}</view>
        </picker>
      </view>
      
      <!-- 日期选择器 -->
      <view class="card">
        <text class="card-title">3.3 日期选择器</text>
        <picker mode="date" bindchange="datePickerChange">
          <view class="picker-text">{{dateValue || '请选择日期'}}</view>
        </picker>
      </view>
      
      <!-- picker-view 嵌入式选择器 -->
      <view class="card">
        <text class="card-title">3.4 picker-view 嵌入式选择器</text>
        <picker-view 
          indicator-style="height: 50px;" 
          style="width: 100%; height: 150px;" 
          value="{{pickerViewValue}}" 
          bindchange="pickerViewChange">
          <picker-view-column>
            <view wx:for="{{province}}" wx:key="*this" style="line-height: 50px;">{{item}}</view>
          </picker-view-column>
          <picker-view-column>
            <view wx:for="{{city}}" wx:key="*this" style="line-height: 50px;">{{item}}</view>
          </picker-view-column>
        </picker-view>
        <view class="result-text">
          选中：{{province[pickerViewValue[0] || 0]}} - {{city[pickerViewValue[1] || 0]}}
        </view>
      </view>
    </view>
    
    <!-- 分割线 -->
    <view class="divider"></view>
    
    <!-- 4. form 表单综合案例 -->
    <view class="sub-section">
      <view class="sub-section-title">4. form 表单综合案例</view>
      <form bindsubmit="formSubmit" bindreset="formReset">
        <view class="card">
          <text class="card-title">输入框</text>
          <input name="username" placeholder="请输入用户名" value="{{formData.username}}" />
        </view>
        
        <view class="card">
          <text class="card-title">单选框</text>
          <radio-group name="gender">
            <label><radio value="male"/>男</label>
            <label><radio value="female"/>女</label>
          </radio-group>
        </view>
        
        <view class="card">
          <text class="card-title">多选框</text>
          <checkbox-group name="hobby">
            <label><checkbox value="reading"/>阅读</label>
            <label><checkbox value="sports"/>运动</label>
            <label><checkbox value="music"/>音乐</label>
          </checkbox-group>
        </view>
        
        <view class="card">
          <text class="card-title">开关</text>
          <switch name="notification"/>
        </view>
        
        <view class="card">
          <text class="card-title">滑动条</text>
          <slider name="score" min="0" max="100" show-value/>
        </view>
        
        <view class="card">
          <text class="card-title">选择器</text>
          <picker name="city" mode="selector" range="{{['北京', '上海', '广州', '深圳']}}">
            <view class="picker-text">请选择城市</view>
          </picker>
        </view>
        
        <view class="btn-group">
          <button class="btn btn-primary" formType="submit">提交</button>
          <button class="btn btn-default" formType="reset">重置</button>
        </view>
      </form>
      
      <view class="result-text" wx:if="{{formSubmitResult}}">
        表单提交数据：{{formSubmitResult}}
      </view>
    </view>
    
  </view>
  
</view>