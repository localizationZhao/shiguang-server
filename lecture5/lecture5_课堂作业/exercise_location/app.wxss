page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #ff5400;
}

.btn {
  width: 100%;
  height: 88rpx;
  background-color: #ff5400;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.btn-outline {
  background-color: #fff;
  color: #ff5400;
  border: 2rpx solid #ff5400;
}

.result-area {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eee;
}

.result-item:last-child {
  border-bottom: none;
}

.result-label {
  font-size: 28rpx;
  color: #666;
  width: 200rpx;
}

.result-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  text-align: right;
  word-break: break-all;
}

.status-text {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  padding: 20rpx 0;
}

.error-text {
  font-size: 26rpx;
  color: #ff4444;
  text-align: center;
  padding: 20rpx 0;
}

.divider {
  height: 20rpx;
  background-color: #f5f5f5;
}