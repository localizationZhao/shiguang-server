<view class="container">
  <view class="section">
    <view class="section-title">模块一：获取当前位置 (wx.getLocation)</view>
    <button class="btn" bindtap="getCurrentLocation">获取当前位置</button>
    <view class="result-area" wx:if="{{currentLocation.latitude}}">
      <view class="result-item">
        <text class="result-label">纬度 (latitude)</text>
        <text class="result-value">{{currentLocation.latitude}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">经度 (longitude)</text>
        <text class="result-value">{{currentLocation.longitude}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">速度 (speed)</text>
        <text class="result-value">{{currentLocation.speed || '0'}} m/s</text>
      </view>
      <view class="result-item">
        <text class="result-label">位置精度 (accuracy)</text>
        <text class="result-value">{{currentLocation.accuracy}} m</text>
      </view>
      <view class="result-item">
        <text class="result-label">海拔高度 (altitude)</text>
        <text class="result-value">{{currentLocation.altitude || '0'}} m</text>
      </view>
      <view class="result-item">
        <text class="result-label">水平精度 (horizontalAccuracy)</text>
        <text class="result-value">{{currentLocation.horizontalAccuracy || '0'}} m</text>
      </view>
      <view class="result-item">
        <text class="result-label">垂直精度 (verticalAccuracy)</text>
        <text class="result-value">{{currentLocation.verticalAccuracy || '0'}} m</text>
      </view>
    </view>
    <view class="status-text" wx:elif="{{!currentLocationError && !currentLocation.latitude}}">点击按钮获取当前位置信息</view>
    <view class="error-text" wx:if="{{currentLocationError}}">{{currentLocationError}}</view>
  </view>

  <view class="section">
    <view class="section-title">模块二：选择地图位置 (wx.chooseLocation)</view>
    <button class="btn" bindtap="chooseLocation">选择地图位置</button>
    <view class="result-area" wx:if="{{selectedLocation.name}}">
      <view class="result-item">
        <text class="result-label">位置名称 (name)</text>
        <text class="result-value">{{selectedLocation.name}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">详细地址 (address)</text>
        <text class="result-value">{{selectedLocation.address}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">纬度 (latitude)</text>
        <text class="result-value">{{selectedLocation.latitude}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">经度 (longitude)</text>
        <text class="result-value">{{selectedLocation.longitude}}</text>
      </view>
    </view>
    <view class="status-text" wx:elif="{{!chooseLocationError && !selectedLocation.name}}">点击按钮选择地图位置</view>
    <view class="error-text" wx:if="{{chooseLocationError}}">{{chooseLocationError}}</view>
  </view>

  <view class="section">
    <view class="section-title">模块三：打开地图位置 (wx.openLocation)</view>
    <button class="btn" bindtap="openMapLocation" disabled="{{!(currentLocation.latitude || selectedLocation.latitude)}}">打开地图位置</button>
    <button class="btn btn-outline" bindtap="openCurrentLocation" disabled="{{!currentLocation.latitude}}">打开当前位置</button>
    <button class="btn btn-outline" bindtap="openSelectedLocation" disabled="{{!selectedLocation.latitude}}">打开选中位置</button>
    <view class="status-text" wx:if="{{!(currentLocation.latitude || selectedLocation.latitude)}}">请先获取或选择一个位置</view>
    <view class="status-text" wx:elif="{{!openLocationError}}">点击按钮在地图中查看位置</view>
    <view class="error-text" wx:if="{{openLocationError}}">{{openLocationError}}</view>
  </view>

  <view class="section">
    <view class="section-title">模块四：位置授权管理 (wx.authorize + wx.openSetting)</view>
    <button class="btn" bindtap="checkAuthStatus">检测授权状态</button>
    <button class="btn btn-outline" bindtap="requestAuth">申请位置权限</button>
    <button class="btn btn-outline" bindtap="openSettings">打开设置页</button>
    <view class="result-area" wx:if="{{authStatus}}">
      <view class="result-item">
        <text class="result-label">授权状态</text>
        <text class="result-value">{{authStatus}}</text>
      </view>
    </view>
    <view class="status-text" wx:elif="{{!authError}}">点击按钮检测或申请位置权限</view>
    <view class="error-text" wx:if="{{authError}}">{{authError}}</view>
  </view>
</view>